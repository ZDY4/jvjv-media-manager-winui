<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.VideoViewportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <MediaPlayerElement x:Name="VideoPlayer"
                            x:FieldModifier="public"
                            AreTransportControlsEnabled="False"
                            AutoPlay="True"
                            Visibility="Collapsed"
                            Stretch="Uniform" />

        <Border x:Name="VideoLoadingPreviewHost"
                x:FieldModifier="public"
                Background="{ThemeResource PlayerSurfaceBrush}"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Image x:Name="VideoLoadingPreviewImage"
                   x:FieldModifier="public"
                   Stretch="Uniform"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" />
        </Border>
    </Grid>
</UserControl>
