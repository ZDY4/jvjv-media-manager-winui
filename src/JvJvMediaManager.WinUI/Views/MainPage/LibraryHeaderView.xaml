<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.LibraryHeaderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Spacing="6">
            <Button x:Name="SelectedPlaylistTitleButton"
                    x:FieldModifier="public"
                    Content="{Binding SelectedPlaylistTitle}"
                    Padding="0"
                    HorizontalAlignment="Left"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="{ThemeResource RadiusSmall}"
                    Foreground="{ThemeResource TextBrush}"
                    FontSize="14.3"
                    FontWeight="SemiBold"
                    Visibility="{Binding SelectedPlaylistTitleVisibility}"
                    ToolTipService.ToolTip="点击重命名播放列表" />

            <StackPanel x:Name="MediaActionsPanel"
                        x:FieldModifier="public"
                        Orientation="Horizontal"
                        Spacing="4">
                <Button x:Name="RefreshButton"
                        x:FieldModifier="public"
                        Style="{StaticResource PanelIconButtonStyle}"
                        Visibility="{Binding RefreshButtonVisibility}"
                        ToolTipService.ToolTip="刷新">
                    <FontIcon Glyph="&#xE72C;" />
                </Button>
                <Button x:Name="ViewModeToggleButton"
                        x:FieldModifier="public"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTipService.ToolTip="{Binding ViewModeToggleToolTip}">
                    <FontIcon Glyph="{Binding ViewModeToggleGlyph}" />
                </Button>
                <Button x:Name="FolderGroupToggleButton"
                        x:FieldModifier="public"
                        Style="{StaticResource PanelIconButtonStyle}"
                        IsEnabled="{Binding HasMediaFolderGroups}"
                        ToolTipService.ToolTip="{Binding MediaFolderGroupToggleToolTip}">
                    <FontIcon Glyph="{Binding MediaFolderGroupToggleGlyph}" />
                </Button>
                <Button x:Name="SortButton"
                        x:FieldModifier="public"
                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                        Content="{Binding SortButtonText}"
                        Padding="10,4"
                        ToolTipService.ToolTip="{Binding SortButtonToolTip}">
                </Button>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Column="1"
              HorizontalAlignment="Right"
              MaxWidth="360">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="StatusText"
                       x:FieldModifier="public"
                       Text="{Binding StatusMessage}"
                       Foreground="{ThemeResource MutedTextBrush}"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis" />
            <Grid Grid.Row="1"
                  Margin="0,4,0,0"
                  ColumnSpacing="6"
                  Visibility="{Binding ScanProgressVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar x:Name="ScanProgressBar"
                             x:FieldModifier="public"
                             Height="3"
                             VerticalAlignment="Center"
                             IsIndeterminate="{Binding ScanProgressIsIndeterminate}"
                             Minimum="0"
                             Maximum="{Binding ScanProgressMaximum}"
                             Value="{Binding ScanProgressValue}" />
                <Button x:Name="CancelScanButton"
                        x:FieldModifier="public"
                        Grid.Column="1"
                        Style="{StaticResource PanelIconButtonStyle}"
                        Visibility="{Binding ScanCancelButtonVisibility}"
                        ToolTipService.ToolTip="取消扫描">
                    <FontIcon Glyph="&#xE711;" />
                </Button>
            </Grid>
            <TextBlock x:Name="ScanPathText"
                       x:FieldModifier="public"
                       Grid.Row="2"
                       Margin="0,2,0,0"
                       Text="{Binding ScanCurrentPath}"
                       Foreground="{ThemeResource SubtleTextBrush}"
                       FontSize="10"
                       TextTrimming="CharacterEllipsis"
                       Visibility="{Binding ScanPathVisibility}" />
        </Grid>
    </Grid>
</UserControl>
