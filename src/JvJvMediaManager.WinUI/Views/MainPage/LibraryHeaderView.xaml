<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.LibraryHeaderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Spacing="8">
            <Button x:Name="SelectedPlaylistTitleButton"
                    x:FieldModifier="public"
                    Padding="0"
                    HorizontalAlignment="Left"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="0"
                    Foreground="{ThemeResource TextBrush}"
                    FontSize="14.3"
                    FontWeight="SemiBold"
                    Visibility="Collapsed"
                    ToolTipService.ToolTip="点击重命名播放列表" />

            <StackPanel x:Name="MediaActionsPanel"
                        x:FieldModifier="public"
                        Orientation="Horizontal"
                        Spacing="6">
                <Button x:Name="RefreshButton"
                        x:FieldModifier="public"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTipService.ToolTip="刷新">
                    <FontIcon Glyph="&#xE72C;" />
                </Button>
                <Button x:Name="ViewModeToggleButton"
                        x:FieldModifier="public"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTipService.ToolTip="切换视图">
                    <FontIcon Glyph="&#xECA5;" />
                </Button>
                <Button x:Name="SortButton"
                        x:FieldModifier="public"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTipService.ToolTip="排序">
                    <FontIcon Glyph="&#xE8CB;" />
                </Button>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Column="1"
              HorizontalAlignment="Right"
              MaxWidth="240">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="StatusText"
                       x:FieldModifier="public"
                       Foreground="{ThemeResource MutedTextBrush}"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis" />
            <ProgressBar x:Name="ScanProgressBar"
                         x:FieldModifier="public"
                         Grid.Row="1"
                         Margin="0,6,0,0"
                         Height="3"
                         Visibility="Collapsed"
                         Minimum="0"
                         Maximum="1"
                         Value="0" />
            <TextBlock x:Name="ScanPathText"
                       x:FieldModifier="public"
                       Grid.Row="2"
                       Margin="0,4,0,0"
                       Foreground="{ThemeResource SubtleTextBrush}"
                       FontSize="10"
                       TextTrimming="CharacterEllipsis"
                       Visibility="Collapsed" />
        </Grid>
    </Grid>
</UserControl>
