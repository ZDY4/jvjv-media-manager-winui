<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.TransportControlBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="ControlBar"
            x:FieldModifier="public"
            VerticalAlignment="Bottom"
            Margin="16"
            Padding="12"
            Background="{ThemeResource ControlBarBrush}"
            BorderThickness="0"
            CornerRadius="0"
            Visibility="{Binding ControlBarVisibility}"
            Opacity="{Binding ControlBarOpacity}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Slider x:Name="ProgressSlider"
                    x:FieldModifier="public"
                    Grid.Row="0"
                    Minimum="0"
                    Maximum="1"
                    Value="0"
                    SmallChange="1"
                    LargeChange="10" />

            <Grid Grid.Row="1"
                  ColumnSpacing="10"
                  Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <AppBarButton x:Name="PlayPauseButton"
                              x:FieldModifier="public"
                              Grid.Column="0"
                              ToolTipService.ToolTip="播放 / 暂停">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE768;" />
                    </AppBarButton.Icon>
                </AppBarButton>

                <Border Grid.Column="1"
                        Padding="8,4"
                        Background="{ThemeResource PlayerInfoBrush}"
                        BorderThickness="0"
                        CornerRadius="4"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="4">
                        <TextBlock x:Name="CurrentTimeText"
                                   x:FieldModifier="public"
                                   Text="{Binding CurrentTimeText}"
                                   Foreground="{ThemeResource TextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="/"
                                   Foreground="{ThemeResource MutedTextBrush}"
                                   FontSize="12" />
                        <TextBlock x:Name="TotalTimeText"
                                   x:FieldModifier="public"
                                   Text="{Binding TotalTimeText}"
                                   Foreground="{ThemeResource MutedTextBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button x:Name="VolumeButton"
                            x:FieldModifier="public"
                            Style="{StaticResource PanelIconButtonStyle}"
                            ToolTipService.ToolTip="音量">
                        <FontIcon Glyph="&#xE767;" />
                    </Button>
                    <Slider x:Name="VolumeSlider"
                            x:FieldModifier="public"
                            Width="110"
                            Minimum="0"
                            Maximum="1"
                            Value="0.8" />
                </StackPanel>

                <Button x:Name="PlaybackModeButton"
                        x:FieldModifier="public"
                        Grid.Column="4"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTipService.ToolTip="播放模式">
                    <FontIcon Glyph="&#xE8EE;" />
                </Button>
                <Button x:Name="ClipModeToggleButton"
                        x:FieldModifier="public"
                        Grid.Column="5"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTipService.ToolTip="进入剪辑">
                    <FontIcon Glyph="&#xE7C8;" />
                </Button>
                <Button x:Name="FullScreenButton"
                        x:FieldModifier="public"
                        Grid.Column="6"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTipService.ToolTip="全屏">
                    <FontIcon Glyph="&#xE740;" />
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
