<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.PlayerPaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mainPage="using:JvJvMediaManager.Views.MainPageParts">

    <Border Margin="4,0,0,0"
            Background="{ThemeResource PlayerSurfaceBrush}"
            BorderThickness="0"
            CornerRadius="0">
        <Grid x:Name="PlayerRoot"
              x:FieldModifier="public"
              Background="Transparent">
            <Rectangle Fill="{ThemeResource WindowAmbientBrush}"
                       IsHitTestVisible="False" />

            <mainPage:EmptyStateView x:Name="EmptyStateView"
                                     x:FieldModifier="public" />
            <mainPage:VideoViewportView x:Name="VideoViewport"
                                        x:FieldModifier="public" />
            <mainPage:ImageViewportView x:Name="ImageViewport"
                                        x:FieldModifier="public" />

            <Grid x:Name="PlayerOverlay"
                  x:FieldModifier="public">
                <mainPage:PlayerInfoOverlayView x:Name="InfoOverlay"
                                                x:FieldModifier="public" />
                <mainPage:PlayerNavigationOverlayView x:Name="NavigationOverlay"
                                                      x:FieldModifier="public" />

                <Border x:Name="ImageZoomBadge"
                        x:FieldModifier="public"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="16"
                        Padding="10,5"
                        Background="{ThemeResource ZoomBadgeBrush}"
                        BorderThickness="0"
                        CornerRadius="0"
                        Visibility="{Binding ImagePreview.ZoomBadgeVisibility}"
                        IsHitTestVisible="False">
                    <TextBlock x:Name="ImageZoomText"
                               x:FieldModifier="public"
                               Text="{Binding ImagePreview.ZoomText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                </Border>

                <mainPage:TransportControlBarView x:Name="TransportBar"
                                                  x:FieldModifier="public"
                                                  DataContext="{Binding VideoPlayback}" />
                <mainPage:ClipEditorBarView x:Name="ClipBarView"
                                            x:FieldModifier="public"
                                            DataContext="{Binding ClipEditor}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
