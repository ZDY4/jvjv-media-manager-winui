<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.PlayerPaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mainPage="using:JvJvMediaManager.Views.MainPageParts"
    xmlns:viewModels="using:JvJvMediaManager.ViewModels.MainPage">

    <UserControl.Resources>
        <Style x:Key="ShortcutHintButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryToolbarButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
    </UserControl.Resources>

    <Border x:Name="PlayerShell"
            Margin="0"
            Background="Transparent"
            BorderThickness="0"
            CornerRadius="0">
        <Grid x:Name="PlayerRoot"
              x:FieldModifier="public"
              Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Rectangle Fill="{ThemeResource PlayerSurfaceBrush}"
                       Grid.RowSpan="2"
                       IsHitTestVisible="False" />
            <Rectangle Fill="{ThemeResource PlayerSurfaceTintBrush}"
                       Grid.RowSpan="2"
                       IsHitTestVisible="False" />
            <Rectangle Fill="{ThemeResource WindowAmbientBrush}"
                       Grid.RowSpan="2"
                       IsHitTestVisible="False" />

            <mainPage:EmptyStateView x:Name="EmptyStateView"
                                     Grid.Row="0"
                                     x:FieldModifier="public" />
            <mainPage:VideoViewportView x:Name="VideoViewport"
                                        Grid.Row="0"
                                        x:FieldModifier="public" />
            <mainPage:ImageViewportView x:Name="ImageViewport"
                                        Grid.Row="0"
                                        x:FieldModifier="public" />

            <Grid x:Name="PlayerOverlay"
                  Grid.Row="0"
                  x:FieldModifier="public">
                <mainPage:PlayerInfoOverlayView x:Name="InfoOverlay"
                                                x:FieldModifier="public" />
                <mainPage:PlayerNavigationOverlayView x:Name="NavigationOverlay"
                                                      x:FieldModifier="public" />

                <Border x:Name="ImageZoomBadge"
                        x:FieldModifier="public"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="16"
                        Padding="10,5"
                        Background="{ThemeResource ZoomBadgeBrush}"
                        BorderThickness="0"
                        CornerRadius="{ThemeResource RadiusMedium}"
                        Visibility="{Binding ImagePreview.ZoomBadgeVisibility}"
                        IsHitTestVisible="False">
                    <TextBlock x:Name="ImageZoomText"
                               x:FieldModifier="public"
                               Text="{Binding ImagePreview.ZoomText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                </Border>

                <Border x:Name="ShortcutHintContainer"
                        x:FieldModifier="public"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="16,16,16,84"
                        Padding="8,5"
                        Background="#16000000"
                        BorderBrush="#24FFFFFF"
                        BorderThickness="1"
                        CornerRadius="{ThemeResource RadiusMedium}"
                        Visibility="{Binding ShortcutHintVisibility}">
                    <StackPanel MaxWidth="240"
                                Spacing="2">
                        <TextBlock Text="{Binding ShortcutHintEmptyStateText}"
                                   Visibility="{Binding ShortcutHintEmptyStateVisibility}"
                                   Foreground="{ThemeResource TextBrush}"
                                   FontSize="10"
                                   FontWeight="Normal"
                                   Opacity="0.68"
                                   TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding ShortcutHintItems}"
                                      Visibility="{Binding ShortcutHintItemsVisibility}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:NumpadTagShortcutHintItem">
                                    <Button Click="ShortcutHintButton_Click"
                                            Style="{StaticResource ShortcutHintButtonStyle}"
                                            Tag="{Binding Digit}">
                                        <TextBlock Text="{Binding DisplayText}"
                                                   Foreground="{ThemeResource TextBrush}"
                                                   FontSize="10"
                                                   FontWeight="Normal"
                                                   Opacity="0.78"
                                                   TextWrapping="Wrap" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <mainPage:TransportControlBarView x:Name="TransportBar"
                                                  x:FieldModifier="public"
                                                  DataContext="{Binding VideoPlayback}" />
            </Grid>

            <mainPage:ClipEditorBarView x:Name="ClipBarView"
                                        Grid.Row="1"
                                        x:FieldModifier="public"
                                        DataContext="{Binding ClipEditor}" />
        </Grid>
    </Border>
</UserControl>
