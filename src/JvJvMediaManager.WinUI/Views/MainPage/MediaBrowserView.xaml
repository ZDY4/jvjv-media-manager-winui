<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.MediaBrowserView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Views/MainPage/MediaLibraryResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <ListView x:Name="ListView"
                  x:FieldModifier="public"
                  Background="Transparent"
                  ItemContainerStyle="{StaticResource MediaListItemContainerStyle}"
                  ItemTemplate="{StaticResource ListItemTemplate}"
                  IncrementalLoadingTrigger="Edge"
                  IncrementalLoadingThreshold="2"
                  DataFetchSize="1"
                  SelectionMode="Extended"
                  IsItemClickEnabled="True">
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <AddDeleteThemeTransition />
                    <RepositionThemeTransition />
                </TransitionCollection>
            </ListView.ItemContainerTransitions>
        </ListView>

        <GridView x:Name="GridView"
                  x:FieldModifier="public"
                  Tag="140"
                  Visibility="Collapsed"
                  Background="Transparent"
                  ItemContainerStyle="{StaticResource MediaGridItemContainerStyle}"
                  ItemTemplate="{StaticResource GridItemTemplate}"
                  IncrementalLoadingTrigger="Edge"
                  IncrementalLoadingThreshold="2"
                  DataFetchSize="1"
                  SelectionMode="Extended"
                  IsItemClickEnabled="True">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   ItemWidth="140"
                                   ItemHeight="140" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </GridView>
    </Grid>
</UserControl>
