<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.MediaBrowserView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Views/MainPage/MediaLibraryResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <CollectionViewSource x:Key="GroupedMediaItemsSource"
                                  IsSourceGrouped="True"
                                  ItemsPath="VisibleItems" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid"
          x:FieldModifier="public">
        <ListView x:Name="ListView"
                  x:FieldModifier="public"
                  ItemsSource="{Binding Source={StaticResource GroupedMediaItemsSource}}"
                  Visibility="{Binding ListViewVisibility}"
                  Background="Transparent"
                  ItemContainerStyle="{StaticResource MediaListItemContainerStyle}"
                  ItemTemplate="{StaticResource ListItemTemplate}"
                  DataFetchSize="1"
                  SelectionMode="Extended"
                  CanDragItems="True"
                  IsItemClickEnabled="False">
            <ListView.GroupStyle>
                <GroupStyle HeaderTemplate="{StaticResource MediaFolderGroupHeaderTemplate}" />
            </ListView.GroupStyle>
        </ListView>

        <GridView x:Name="GridView"
                  x:FieldModifier="public"
                  ItemsSource="{Binding Source={StaticResource GroupedMediaItemsSource}}"
                  Tag="{Binding IconSize}"
                  Visibility="{Binding GridViewVisibility}"
                  Background="Transparent"
                  ItemContainerStyle="{StaticResource MediaGridItemContainerStyle}"
                  ItemTemplate="{StaticResource GridItemTemplate}"
                  DataFetchSize="1"
                  SelectionMode="Extended"
                  CanDragItems="True"
                  IsItemClickEnabled="False">
            <GridView.GroupStyle>
                <GroupStyle HeaderTemplate="{StaticResource MediaFolderGroupHeaderTemplate}" />
            </GridView.GroupStyle>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   ItemWidth="140"
                                   ItemHeight="140" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </GridView>

        <Canvas x:Name="SelectionCanvas"
                x:FieldModifier="public"
                IsHitTestVisible="False">
            <Rectangle x:Name="SelectionRectangle"
                       x:FieldModifier="public"
                       Visibility="Collapsed"
                       RadiusX="4"
                       RadiusY="4"
                       Stroke="{ThemeResource LibrarySelectionStrongBrush}"
                       StrokeThickness="1.5"
                       Fill="{ThemeResource LibrarySelectionBrush}"
                       Opacity="0.45" />
        </Canvas>
    </Grid>
</UserControl>
