<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.EmptyStateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid"
          x:FieldModifier="public"
          Visibility="Visible">
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="24"
                Background="{ThemeResource EmptyStateCardBrush}"
                BorderThickness="0"
                CornerRadius="0">
            <StackPanel HorizontalAlignment="Center"
                        Spacing="6">
                <Border Width="56"
                        Height="56"
                        Background="{ThemeResource EmptyStateIconBrush}"
                        CornerRadius="0"
                        HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE8B9;"
                              FontSize="24"
                              Foreground="{ThemeResource AccentBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="选择媒体"
                           Foreground="{ThemeResource TextBrush}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="从左侧导入、搜索并浏览媒体。"
                           Foreground="{ThemeResource MutedTextBrush}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock Text="PageUp / PageDown 切换上一个或下一个"
                           Foreground="{ThemeResource SubtleTextBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
