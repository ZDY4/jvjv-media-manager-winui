<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.PlayerInfoOverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="PlayerInfoBadge"
            x:FieldModifier="public"
            Visibility="{Binding PlayerInfoVisibility}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="16"
            Padding="10,8"
            Background="{ThemeResource PlayerInfoBrush}"
            BorderThickness="0"
            CornerRadius="{ThemeResource RadiusMedium}"
            IsHitTestVisible="False">
        <StackPanel Spacing="2">
            <TextBlock x:Name="FileNameText"
                       x:FieldModifier="public"
                       Text="{Binding PlayerFileName}"
                       Foreground="{ThemeResource TextBrush}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="ResolutionText"
                       x:FieldModifier="public"
                       Text="{Binding PlayerResolution}"
                       Foreground="{ThemeResource MutedTextBrush}"
                       FontSize="12" />
        </StackPanel>
    </Border>
</UserControl>
