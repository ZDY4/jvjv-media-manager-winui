<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.PlaylistRailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Views/MainPage/MediaLibraryResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{ThemeResource SurfaceAltBrush}">
        <Grid Padding="8,10,8,10"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Button x:Name="MediaTabButton"
                    x:FieldModifier="public"
                    Style="{StaticResource PanelIconButtonStyle}"
                    Background="{Binding SelectedPlaylist, Converter={StaticResource MediaTabBackgroundBrushConverter}}"
                    Foreground="{Binding SelectedPlaylist, Converter={StaticResource MediaTabForegroundBrushConverter}}"
                    ToolTipService.ToolTip="媒体库">
                <FontIcon Glyph="&#xE8B9;" />
            </Button>

            <Rectangle Grid.Row="1"
                       Height="1"
                       Margin="4,4,4,8"
                       Fill="{ThemeResource SurfaceStrokeBrush}" />

            <ListView x:Name="PlaylistRailListView"
                      x:FieldModifier="public"
                      Grid.Row="2"
                      ItemsSource="{Binding Playlists}"
                      SelectedItem="{Binding SelectedPlaylist, Mode=TwoWay}"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalAlignment="Stretch"
                      ItemContainerStyle="{StaticResource PlaylistRailListItemContainerStyle}"
                      ItemTemplate="{StaticResource PlaylistRailTemplate}"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      CanDragItems="True"
                      CanReorderItems="True"
                      AllowDrop="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Hidden" />

            <Button Grid.Row="3"
                    x:Name="CreatePlaylistRailButton"
                    x:FieldModifier="public"
                    Style="{StaticResource PanelIconButtonStyle}"
                    ToolTipService.ToolTip="添加播放列表">
                <FontIcon Glyph="&#xE710;" />
            </Button>
        </Grid>
    </Border>
</UserControl>
