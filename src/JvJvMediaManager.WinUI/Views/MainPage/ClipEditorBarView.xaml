<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.ClipEditorBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="ClipBar"
            x:FieldModifier="public"
            Margin="16,0,16,16"
            VerticalAlignment="Bottom"
            Padding="14,12"
            Background="{ThemeResource ClipBarBrush}"
            BorderBrush="{ThemeResource ControlBarBorderBrush}"
            BorderThickness="1"
            CornerRadius="{ThemeResource RadiusMedium}"
            Visibility="{Binding Visibility}">
        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            Spacing="6">
                    <Button x:Name="ExitClipModeButton"
                            x:FieldModifier="public"
                            Style="{StaticResource PanelIconButtonStyle}"
                            ToolTipService.ToolTip="退出剪辑">
                        <FontIcon Glyph="&#xE711;" />
                    </Button>
                    <Button x:Name="ClipPlayPauseButton"
                            x:FieldModifier="public"
                            Style="{StaticResource PanelIconButtonStyle}"
                            ToolTipService.ToolTip="播放 / 暂停">
                        <FontIcon Glyph="&#xE768;" />
                    </Button>
                    <Button x:Name="SetClipStartButton"
                            x:FieldModifier="public"
                            Visibility="Collapsed"
                            Style="{StaticResource PanelIconButtonStyle}"
                            ToolTipService.ToolTip="标记入点 (I)">
                        <FontIcon Glyph="&#xE7C1;" />
                    </Button>
                    <Button x:Name="SetClipEndButton"
                            x:FieldModifier="public"
                            Visibility="Collapsed"
                            Style="{StaticResource PanelIconButtonStyle}"
                            ToolTipService.ToolTip="标记出点 (O)">
                        <FontIcon Glyph="&#xE7C5;" />
                    </Button>
                    <Button x:Name="SplitClipButton"
                            x:FieldModifier="public"
                            Style="{StaticResource PanelIconButtonStyle}"
                            ToolTipService.ToolTip="切开当前片段 (S)">
                        <FontIcon Glyph="&#xE16C;" />
                    </Button>
                    <Button x:Name="ClipPlanButton"
                            x:FieldModifier="public"
                            Visibility="Collapsed"
                            Style="{StaticResource PanelIconButtonStyle}"
                            ToolTipService.ToolTip="片段方案">
                        <FontIcon Glyph="&#xE8A5;" />
                    </Button>
                    <Button x:Name="ClearClipButton"
                            x:FieldModifier="public"
                            Style="{StaticResource PanelIconButtonStyle}"
                            ToolTipService.ToolTip="重置片段">
                        <FontIcon Glyph="&#xE894;" />
                    </Button>
                    <Button x:Name="ExportClipButton"
                            x:FieldModifier="public"
                            Style="{StaticResource PrimaryIconButtonStyle}"
                            ToolTipService.ToolTip="导出剪辑 (E)">
                        <FontIcon Glyph="&#xEDE1;" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Center">
                    <Button x:Name="TimelineZoomOutButton"
                            x:FieldModifier="public"
                            Visibility="Collapsed"
                            Style="{StaticResource PanelIconButtonStyle}"
                            ToolTipService.ToolTip="缩小时间线">
                        <FontIcon Glyph="&#xE1D6;" />
                    </Button>
                    <Border Padding="10,5"
                            Background="{ThemeResource PlayerInfoBrush}"
                            CornerRadius="{ThemeResource RadiusSmall}">
                        <TextBlock x:Name="TimelineZoomText"
                                   x:FieldModifier="public"
                                   Text="缩放：100%"
                                   Foreground="{ThemeResource TextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Button x:Name="TimelineZoomInButton"
                            x:FieldModifier="public"
                            Visibility="Collapsed"
                            Style="{StaticResource PanelIconButtonStyle}"
                            ToolTipService.ToolTip="放大时间线">
                        <FontIcon Glyph="&#xE114;" />
                    </Button>
                    <Button x:Name="TimelineZoomResetButton"
                            x:FieldModifier="public"
                            Visibility="Collapsed"
                            Style="{StaticResource PanelIconButtonStyle}"
                            ToolTipService.ToolTip="重置缩放">
                        <FontIcon Glyph="&#xE777;" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Spacing="2"
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="TimelineCursorText"
                               x:FieldModifier="public"
                               Text="游标：0:00 / 0:00"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right" />
                    <TextBlock Text="拖边界微调，单击片段后可 Delete 删除，Ctrl+滚轮缩放，右键按住平移"
                               Foreground="{ThemeResource MutedTextBrush}"
                               FontSize="11"
                               HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Padding="12,10"
                    Background="{ThemeResource ControlBarOverlayBrush}"
                    BorderBrush="{ThemeResource SurfaceStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource RadiusMedium}">
                <Grid RowSpacing="8">
                    <TextBlock Text="剪辑时间线"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />

                    <Grid x:Name="TimelineViewport"
                          x:FieldModifier="public"
                          Height="92"
                          Margin="0,2,0,0"
                          Grid.Row="1">
                        <ScrollViewer x:Name="TimelineScrollViewer"
                                      x:FieldModifier="public"
                                      HorizontalScrollMode="Enabled"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollMode="Disabled"
                                      VerticalScrollBarVisibility="Disabled"
                                      ZoomMode="Disabled"
                                      IsTabStop="False">
                            <Canvas x:Name="TimelineContentCanvas"
                                    x:FieldModifier="public"
                                    Height="92">
                                <Border x:Name="TimelineScrubSurface"
                                        x:FieldModifier="public"
                                        Background="Transparent" />

                                <Canvas x:Name="TimelineThumbnailCanvas"
                                        x:FieldModifier="public"
                                        IsHitTestVisible="False" />

                                <Border x:Name="TimelineTrackBackground"
                                        x:FieldModifier="public"
                                        Height="10"
                                        Background="{ThemeResource PlayerInfoBrush}"
                                        CornerRadius="5"
                                        IsHitTestVisible="False" />

                                <Canvas x:Name="TimelineSegmentsCanvas"
                                        x:FieldModifier="public"
                                        IsHitTestVisible="True" />

                                <Rectangle x:Name="TimelinePlayhead"
                                           x:FieldModifier="public"
                                           Width="2"
                                           RadiusX="1"
                                           RadiusY="1"
                                           Fill="{ThemeResource AccentStrongBrush}"
                                           IsHitTestVisible="False" />

                                <Border x:Name="TimelineStartHandle"
                                        x:FieldModifier="public"
                                        Width="16"
                                        Height="34"
                                        Background="{ThemeResource AccentBrush}"
                                        BorderBrush="{ThemeResource AccentForegroundBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{ThemeResource RadiusSmall}">
                                    <TextBlock Text="I"
                                               Foreground="{ThemeResource AccentForegroundBrush}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <Border x:Name="TimelineEndHandle"
                                        x:FieldModifier="public"
                                        Width="16"
                                        Height="34"
                                        Background="{ThemeResource AccentStrongBrush}"
                                        BorderBrush="{ThemeResource AccentForegroundBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{ThemeResource RadiusSmall}">
                                    <TextBlock Text="O"
                                               Foreground="{ThemeResource AccentForegroundBrush}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Canvas>
                        </ScrollViewer>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TimelineStartLabel"
                                   x:FieldModifier="public"
                                   Text="0:00"
                                   Foreground="{ThemeResource MutedTextBrush}"
                                   FontSize="11" />
                        <TextBlock x:Name="TimelineMidLabel"
                                   x:FieldModifier="public"
                                   Grid.Column="1"
                                   Text="0:00"
                                   Foreground="{ThemeResource MutedTextBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="TimelineEndLabel"
                                   x:FieldModifier="public"
                                   Grid.Column="2"
                                   Text="0:00"
                                   Foreground="{ThemeResource MutedTextBrush}"
                                   FontSize="11" />
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Spacing="8">
                <Border Padding="8,4"
                        Background="{ThemeResource PlayerInfoBrush}"
                        BorderThickness="0"
                        CornerRadius="{ThemeResource RadiusSmall}">
                    <TextBlock x:Name="ClipStartText"
                               x:FieldModifier="public"
                               Text="{Binding ClipStartText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12" />
                </Border>
                <Border Padding="8,4"
                        Background="{ThemeResource PlayerInfoBrush}"
                        BorderThickness="0"
                        CornerRadius="{ThemeResource RadiusSmall}">
                    <TextBlock x:Name="ClipEndText"
                               x:FieldModifier="public"
                               Text="{Binding ClipEndText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12" />
                </Border>
                <Border Padding="8,4"
                        Background="{ThemeResource PlayerInfoBrush}"
                        BorderThickness="0"
                        CornerRadius="{ThemeResource RadiusSmall}">
                    <TextBlock x:Name="ClipDurationText"
                               x:FieldModifier="public"
                               Text="{Binding ClipDurationText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Spacing="8">
                <Border Padding="8,4"
                        Background="{ThemeResource ScopeBadgeBrush}"
                        BorderThickness="0"
                        CornerRadius="{ThemeResource RadiusSmall}">
                    <TextBlock x:Name="ClipModeText"
                               x:FieldModifier="public"
                               Text="{Binding ClipModeText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12" />
                </Border>
                <Border Padding="8,4"
                        Background="{ThemeResource StatusBadgeBrush}"
                        BorderThickness="0"
                        CornerRadius="{ThemeResource RadiusSmall}">
                    <TextBlock x:Name="ClipSegmentCountText"
                               x:FieldModifier="public"
                               Text="{Binding ClipSegmentCountText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12" />
                </Border>
                <Border Padding="8,4"
                        Background="{ThemeResource StatusBadgeBrush}"
                        BorderThickness="0"
                        CornerRadius="{ThemeResource RadiusSmall}"
                        MaxWidth="220">
                    <TextBlock x:Name="ClipOutputText"
                               x:FieldModifier="public"
                               Text="{Binding ClipOutputText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
                <ProgressBar x:Name="ClipExportProgressBar"
                             x:FieldModifier="public"
                             Width="220"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue}"
                             Visibility="{Binding ProgressVisibility}" />
                <TextBlock x:Name="ClipStatusText"
                           x:FieldModifier="public"
                           Text="{Binding StatusText}"
                           Foreground="{ThemeResource MutedTextBrush}"
                           FontSize="12"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
