<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.ClipEditorBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="ClipBar"
            x:FieldModifier="public"
            Margin="16,0,16,16"
            VerticalAlignment="Bottom"
            Padding="10"
            Background="{ThemeResource ClipBarBrush}"
            BorderThickness="0"
            CornerRadius="0"
            Visibility="{Binding Visibility}">
        <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button x:Name="SetClipStartButton"
                        x:FieldModifier="public"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTipService.ToolTip="标记入点 (I)">
                    <FontIcon Glyph="&#xE7C1;" />
                </Button>
                <Button x:Name="SetClipEndButton"
                        x:FieldModifier="public"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTipService.ToolTip="标记出点 (O)">
                    <FontIcon Glyph="&#xE7C5;" />
                </Button>
                <Button x:Name="ClipPlanButton"
                        x:FieldModifier="public"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTipService.ToolTip="片段方案">
                    <FontIcon Glyph="&#xE8A5;" />
                </Button>
                <Button x:Name="ClearClipButton"
                        x:FieldModifier="public"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTipService.ToolTip="重置区间">
                    <FontIcon Glyph="&#xE894;" />
                </Button>
                <Button x:Name="ExportClipButton"
                        x:FieldModifier="public"
                        Style="{StaticResource PrimaryIconButtonStyle}"
                        ToolTipService.ToolTip="导出剪辑 (E)">
                    <FontIcon Glyph="&#xEDE1;" />
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Padding="8,4"
                        Background="{ThemeResource PlayerInfoBrush}"
                        BorderThickness="0"
                        CornerRadius="4">
                    <TextBlock x:Name="ClipStartText"
                               x:FieldModifier="public"
                               Text="{Binding ClipStartText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12" />
                </Border>
                <Border Padding="8,4"
                        Background="{ThemeResource PlayerInfoBrush}"
                        BorderThickness="0"
                        CornerRadius="4">
                    <TextBlock x:Name="ClipEndText"
                               x:FieldModifier="public"
                               Text="{Binding ClipEndText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12" />
                </Border>
                <Border Padding="8,4"
                        Background="{ThemeResource PlayerInfoBrush}"
                        BorderThickness="0"
                        CornerRadius="4">
                    <TextBlock x:Name="ClipDurationText"
                               x:FieldModifier="public"
                               Text="{Binding ClipDurationText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12" />
                </Border>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Padding="8,4"
                        Background="{ThemeResource ScopeBadgeBrush}"
                        BorderThickness="0"
                        CornerRadius="4">
                    <TextBlock x:Name="ClipModeText"
                               x:FieldModifier="public"
                               Text="{Binding ClipModeText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12" />
                </Border>
                <Border Padding="8,4"
                        Background="{ThemeResource StatusBadgeBrush}"
                        BorderThickness="0"
                        CornerRadius="4">
                    <TextBlock x:Name="ClipSegmentCountText"
                               x:FieldModifier="public"
                               Text="{Binding ClipSegmentCountText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12" />
                </Border>
                <Border Padding="8,4"
                        Background="{ThemeResource StatusBadgeBrush}"
                        BorderThickness="0"
                        CornerRadius="4"
                        MaxWidth="220">
                    <TextBlock x:Name="ClipOutputText"
                               x:FieldModifier="public"
                               Text="{Binding ClipOutputText}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                </Border>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
                <ProgressBar x:Name="ClipExportProgressBar"
                             x:FieldModifier="public"
                             Width="180"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue}"
                             Visibility="{Binding ProgressVisibility}" />
                <TextBlock x:Name="ClipStatusText"
                           x:FieldModifier="public"
                           Text="{Binding StatusText}"
                           Foreground="{ThemeResource MutedTextBrush}"
                           FontSize="12"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
