<ResourceDictionary
    x:Class="JvJvMediaManager.Views.MainPageParts.MediaLibraryResources"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JvJvMediaManager.Models"
    xmlns:utilities="using:JvJvMediaManager.Utilities"
    xmlns:viewModels="using:JvJvMediaManager.ViewModels">

    <LinearGradientBrush x:Key="MediaThumbOverlayBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="{ThemeResource ThumbOverlayStartColor}" Offset="0" />
        <GradientStop Color="{ThemeResource ThumbOverlayMiddleColor}" Offset="0.65" />
        <GradientStop Color="{ThemeResource ThumbOverlayEndColor}" Offset="1" />
    </LinearGradientBrush>

    <utilities:PlaylistBackgroundBrushConverter x:Key="PlaylistBackgroundBrushConverter" />
    <utilities:PlaylistForegroundBrushConverter x:Key="PlaylistForegroundBrushConverter" />
    <utilities:MediaTabBackgroundBrushConverter x:Key="MediaTabBackgroundBrushConverter" />
    <utilities:MediaTabForegroundBrushConverter x:Key="MediaTabForegroundBrushConverter" />
    <utilities:BooleanVisibilityConverter x:Key="BooleanVisibilityConverter" />

    <Style x:Key="MediaTooltipStyle" TargetType="ToolTip">
        <Setter Property="Background" Value="{ThemeResource MediaCardBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource SurfaceStrokeStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="MediaListItemContainerStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="MediaGridItemContainerStyle" TargetType="GridViewItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="6,4,6,10" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="PlaylistRailListItemContainerStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Grid Background="Transparent">
                        <Border x:Name="PlaylistHighlightBackground"
                                Margin="1"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="{ThemeResource RadiusMedium}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="PlaylistSelectionBackground"
                                Background="{ThemeResource LibrarySelectionStrongBrush}"
                                CornerRadius="{ThemeResource RadiusMedium}"
                                Opacity="1"
                                Visibility="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanVisibilityConverter}}" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="2"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="HighlightStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="Highlight">
                                    <VisualState.Setters>
                                        <Setter Target="PlaylistHighlightBackground.Opacity" Value="0.9" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="MediaFolderGroupHeaderTemplate" x:DataType="viewModels:MediaFolderGroupViewModel">
        <ToggleButton IsChecked="{Binding IsCollapsed, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      Margin="0,8,0,6">
            <ToolTipService.ToolTip>
                <ToolTip Content="{Binding FolderPath}" Style="{StaticResource MediaTooltipStyle}" />
            </ToolTipService.ToolTip>
            <Grid ColumnSpacing="8"
                  MinHeight="28"
                  Padding="2,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0"
                          Glyph="{Binding CollapseGlyph}"
                          FontSize="12"
                          Foreground="{ThemeResource MutedTextBrush}"
                          VerticalAlignment="Center" />
                <Grid Grid.Column="1"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding FolderDisplayName}"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <Rectangle Grid.Column="1"
                               Height="1"
                               Margin="10,0,0,0"
                               Fill="{ThemeResource SurfaceStrokeBrush}"
                               VerticalAlignment="Center" />
                </Grid>
                <TextBlock Grid.Column="2"
                           Text="{Binding CountText}"
                           Foreground="{ThemeResource MutedTextBrush}"
                           FontSize="11"
                           VerticalAlignment="Center" />
            </Grid>
        </ToggleButton>
    </DataTemplate>

    <DataTemplate x:Key="ListItemTemplate" x:DataType="viewModels:MediaItemViewModel">
        <Border Padding="6"
                Background="{ThemeResource MediaCardBrush}"
                BorderThickness="0"
                CornerRadius="{ThemeResource RadiusMedium}">
            <ToolTipService.ToolTip>
                <ToolTip Content="{Binding FileSystemPath}" Style="{StaticResource MediaTooltipStyle}" />
            </ToolTipService.ToolTip>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="ListSelectionOverlay"
                        Background="{ThemeResource LibrarySelectionBrush}"
                        BorderThickness="0"
                        CornerRadius="{ThemeResource RadiusMedium}"
                        Opacity="1"
                        Grid.ColumnSpan="2"
                        Visibility="{Binding IsSelected, Converter={StaticResource BooleanVisibilityConverter}}" />
                <Border x:Name="ListNowPlayingTint"
                        Grid.ColumnSpan="2"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="{ThemeResource RadiusMedium}"
                        Opacity="0.18"
                        Canvas.ZIndex="9"
                        IsHitTestVisible="False"
                        Visibility="{Binding IsNowPlaying, Converter={StaticResource BooleanVisibilityConverter}}" />
                <Border x:Name="ListNowPlayingFrame"
                        Grid.ColumnSpan="2"
                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                        BorderThickness="4"
                        CornerRadius="{ThemeResource RadiusMedium}"
                        Canvas.ZIndex="10"
                        IsHitTestVisible="False"
                        Visibility="{Binding IsNowPlaying, Converter={StaticResource BooleanVisibilityConverter}}" />
                <Border x:Name="ListNowPlayingBadge"
                        Grid.ColumnSpan="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="8"
                        Padding="8,4"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="{ThemeResource RadiusSmall}"
                        Canvas.ZIndex="11"
                        IsHitTestVisible="False"
                        Visibility="{Binding IsNowPlaying, Converter={StaticResource BooleanVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE768;"
                                  Foreground="White"
                                  FontSize="11" />
                        <TextBlock Text="播放中"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border x:Name="ListThumbnailHost"
                        Width="72"
                        Height="72"
                        Background="{ThemeResource MediaCardPlaceholderBrush}"
                        CornerRadius="{ThemeResource RadiusSmall}">
                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" Margin="2" />
                </Border>

                <StackPanel Grid.Column="1"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="{ThemeResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding SizeText}"
                                       Foreground="{ThemeResource MutedTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding ResolutionText}"
                                       Foreground="{ThemeResource MutedTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding DurationText}"
                                       Foreground="{ThemeResource MutedTextBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>

                    <Border HorizontalAlignment="Left"
                            Padding="5,2"
                            Background="{ThemeResource MediaTagChipBrush}"
                            CornerRadius="{ThemeResource RadiusSmall}">
                        <TextBlock Text="{Binding TagsText}"
                                   Foreground="{ThemeResource LibraryChipForegroundBrush}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="GridItemTemplate" x:DataType="viewModels:MediaItemViewModel">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <ToolTipService.ToolTip>
                <ToolTip Content="{Binding FileSystemPath}" Style="{StaticResource MediaTooltipStyle}" />
            </ToolTipService.ToolTip>
            <Border HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{ThemeResource MediaCardBrush}"
                    BorderThickness="0"
                    CornerRadius="{ThemeResource RadiusLarge}">
                <Grid>
                    <Border x:Name="GridSelectionOverlay"
                            Background="{ThemeResource LibrarySelectionBrush}"
                            BorderThickness="0"
                            CornerRadius="{ThemeResource RadiusLarge}"
                            Opacity="1"
                            Visibility="{Binding IsSelected, Converter={StaticResource BooleanVisibilityConverter}}" />
                    <Border x:Name="GridNowPlayingTint"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="{ThemeResource RadiusLarge}"
                            Opacity="0.16"
                            Canvas.ZIndex="9"
                            IsHitTestVisible="False"
                            Visibility="{Binding IsNowPlaying, Converter={StaticResource BooleanVisibilityConverter}}" />
                    <Border x:Name="GridNowPlayingFrame"
                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                            BorderThickness="5"
                            CornerRadius="{ThemeResource RadiusLarge}"
                            Canvas.ZIndex="10"
                            IsHitTestVisible="False"
                            Visibility="{Binding IsNowPlaying, Converter={StaticResource BooleanVisibilityConverter}}" />
                    <Border x:Name="GridNowPlayingBadge"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="8"
                            Padding="8,4"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="{ThemeResource RadiusSmall}"
                            Canvas.ZIndex="11"
                            IsHitTestVisible="False"
                            Visibility="{Binding IsNowPlaying, Converter={StaticResource BooleanVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE768;"
                                      Foreground="White"
                                      FontSize="11" />
                            <TextBlock Text="播放中"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Margin="5"
                            Background="{ThemeResource MediaCardPlaceholderBrush}"
                            CornerRadius="{ThemeResource RadiusMedium}">
                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" Margin="2" />
                    </Border>

                    <Border Margin="4"
                            VerticalAlignment="Bottom"
                            Background="{StaticResource MediaThumbOverlayBrush}"
                            CornerRadius="{ThemeResource RadiusMedium}"
                            Padding="6,4">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding FileName}"
                                       Foreground="{ThemeResource TextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding SizeText}"
                                           Foreground="{ThemeResource MutedTextBrush}"
                                           FontSize="9"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ResolutionText}"
                                           Foreground="{ThemeResource MutedTextBrush}"
                                           FontSize="9"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="PlaylistRailTemplate" x:DataType="models:Playlist">
        <Border x:Name="ItemBorder"
                Width="34"
                Height="34"
                Background="{Binding ColorHex, Converter={StaticResource PlaylistBackgroundBrushConverter}}"
                CornerRadius="{ThemeResource RadiusSmall}">
            <TextBlock Text="{Binding RailDisplayText}"
                       Foreground="{Binding ColorHex, Converter={StaticResource PlaylistForegroundBrushConverter}}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       MaxLines="1"
                       TextTrimming="Clip" />
        </Border>
    </DataTemplate>
</ResourceDictionary>
