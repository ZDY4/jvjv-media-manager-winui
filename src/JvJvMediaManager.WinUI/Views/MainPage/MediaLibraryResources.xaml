<ResourceDictionary
    x:Class="JvJvMediaManager.Views.MainPageParts.MediaLibraryResources"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JvJvMediaManager.Models"
    xmlns:utilities="using:JvJvMediaManager.Utilities"
    xmlns:viewModels="using:JvJvMediaManager.ViewModels">

    <LinearGradientBrush x:Key="MediaThumbOverlayBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="{ThemeResource ThumbOverlayStartColor}" Offset="0" />
        <GradientStop Color="{ThemeResource ThumbOverlayMiddleColor}" Offset="0.65" />
        <GradientStop Color="{ThemeResource ThumbOverlayEndColor}" Offset="1" />
    </LinearGradientBrush>

    <utilities:PlaylistBackgroundBrushConverter x:Key="PlaylistBackgroundBrushConverter" />
    <utilities:PlaylistForegroundBrushConverter x:Key="PlaylistForegroundBrushConverter" />
    <utilities:MediaTabBackgroundBrushConverter x:Key="MediaTabBackgroundBrushConverter" />
    <utilities:MediaTabForegroundBrushConverter x:Key="MediaTabForegroundBrushConverter" />
    <utilities:BooleanVisibilityConverter x:Key="BooleanVisibilityConverter" />

    <Style x:Key="MediaListItemContainerStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="MediaGridItemContainerStyle" TargetType="GridViewItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="6,4,6,10" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="PlaylistRailListItemContainerStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Grid Background="Transparent">
                        <Border x:Name="PlaylistSelectionBackground"
                                Background="{ThemeResource LibrarySelectionStrongBrush}"
                                CornerRadius="{ThemeResource RadiusMedium}"
                                Opacity="1"
                                Visibility="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanVisibilityConverter}}" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="2"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="ListItemTemplate" x:DataType="viewModels:MediaItemViewModel">
        <Border Padding="6"
                Background="{ThemeResource MediaCardBrush}"
                BorderThickness="0"
                CornerRadius="{ThemeResource RadiusMedium}">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="ListSelectionOverlay"
                        Background="{ThemeResource LibrarySelectionBrush}"
                        BorderThickness="0"
                        CornerRadius="{ThemeResource RadiusMedium}"
                        Opacity="1"
                        Grid.ColumnSpan="2"
                        Visibility="{Binding IsSelected, Converter={StaticResource BooleanVisibilityConverter}}" />

                <Border x:Name="ListThumbnailHost"
                        Width="72"
                        Height="72"
                        Background="{ThemeResource MediaCardPlaceholderBrush}"
                        CornerRadius="{ThemeResource RadiusSmall}">
                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" Margin="2" />
                </Border>

                <StackPanel Grid.Column="1"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="{ThemeResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding SizeText}"
                                       Foreground="{ThemeResource MutedTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding ResolutionText}"
                                       Foreground="{ThemeResource MutedTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding DurationText}"
                                       Foreground="{ThemeResource MutedTextBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>

                    <Border HorizontalAlignment="Left"
                            Padding="5,2"
                            Background="{ThemeResource MediaTagChipBrush}"
                            CornerRadius="{ThemeResource RadiusSmall}">
                        <TextBlock Text="{Binding TagsText}"
                                   Foreground="{ThemeResource LibraryChipForegroundBrush}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="GridItemTemplate" x:DataType="viewModels:MediaItemViewModel">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Border Width="{Binding ElementName=GridView, Path=Tag}"
                    Height="{Binding ElementName=GridView, Path=Tag}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{ThemeResource MediaCardBrush}"
                    BorderThickness="0"
                    CornerRadius="{ThemeResource RadiusLarge}">
                <Grid>
                    <Border x:Name="GridSelectionOverlay"
                            Background="{ThemeResource LibrarySelectionBrush}"
                            BorderThickness="0"
                            CornerRadius="{ThemeResource RadiusLarge}"
                            Opacity="1"
                            Visibility="{Binding IsSelected, Converter={StaticResource BooleanVisibilityConverter}}" />
                    <Border Margin="5"
                            Background="{ThemeResource MediaCardPlaceholderBrush}"
                            CornerRadius="{ThemeResource RadiusMedium}">
                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" Margin="2" />
                    </Border>

                    <Border Margin="4"
                            VerticalAlignment="Bottom"
                            Background="{StaticResource MediaThumbOverlayBrush}"
                            CornerRadius="{ThemeResource RadiusMedium}"
                            Padding="6,4">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding FileName}"
                                       Foreground="{ThemeResource TextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding SizeText}"
                                           Foreground="{ThemeResource MutedTextBrush}"
                                           FontSize="9"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ResolutionText}"
                                           Foreground="{ThemeResource MutedTextBrush}"
                                           FontSize="9"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="PlaylistRailTemplate" x:DataType="models:Playlist">
        <Border Width="34"
                Height="34"
                Background="{Binding ColorHex, Converter={StaticResource PlaylistBackgroundBrushConverter}}"
                CornerRadius="{ThemeResource RadiusSmall}"
                ToolTipService.ToolTip="{Binding Name}">
            <TextBlock Text="{Binding RailDisplayText}"
                       Foreground="{Binding ColorHex, Converter={StaticResource PlaylistForegroundBrushConverter}}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       MaxLines="1"
                       TextTrimming="Clip" />
        </Border>
    </DataTemplate>
</ResourceDictionary>
