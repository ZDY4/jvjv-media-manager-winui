<UserControl
    x:Class="JvJvMediaManager.Views.MainPageParts.MediaFilterBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="SearchBox"
                 x:FieldModifier="public"
                 PlaceholderText="搜索媒体或输入 #标签"
                 Style="{StaticResource GlassTextBoxStyle}" />

        <ItemsControl x:Name="SelectedTagsControl"
                      x:FieldModifier="public"
                      Grid.Row="1"
                      Margin="0,6,0,0"
                      ItemsSource="{Binding SelectedTags}"
                      Visibility="{Binding SelectedTagsVisibility}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Button x:Name="TagChipButton"
                            Click="TagChipButton_Click"
                            Tag="{Binding}"
                            Margin="0,0,4,4"
                            Padding="6,2"
                            Background="{ThemeResource FilterChipBrush}"
                            Foreground="{ThemeResource AccentBrush}"
                            BorderThickness="0"
                            CornerRadius="4"
                            Content="{Binding}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapGrid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>
</UserControl>
