<Page
    x:Class="JvJvMediaManager.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JvJvMediaManager.Models"
    xmlns:utilities="using:JvJvMediaManager.Utilities"
    xmlns:viewModels="using:JvJvMediaManager.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Space" Invoked="PlayPauseKeyboardAccelerator_Invoked" />
        <KeyboardAccelerator Key="Delete" Invoked="DeleteKeyboardAccelerator_Invoked" />
    </Page.KeyboardAccelerators>

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Page.Resources>
        <AcrylicBrush x:Key="PlayerEdgeNavigationBrush"
                      TintColor="{ThemeResource PlayerEdgeTintColor}"
                      TintOpacity="0.72"
                      TintLuminosityOpacity="0.18"
                      FallbackColor="{ThemeResource PlayerEdgeFallbackColor}" />

        <SolidColorBrush x:Key="PlayerEdgeNavigationButtonBrush" Color="#CC343434" />

        <LinearGradientBrush x:Key="MediaThumbOverlayBrush" StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="{ThemeResource ThumbOverlayStartColor}" Offset="0" />
            <GradientStop Color="{ThemeResource ThumbOverlayMiddleColor}" Offset="0.65" />
            <GradientStop Color="{ThemeResource ThumbOverlayEndColor}" Offset="1" />
        </LinearGradientBrush>

        <utilities:PlaylistBackgroundBrushConverter x:Key="PlaylistBackgroundBrushConverter" />
        <utilities:PlaylistForegroundBrushConverter x:Key="PlaylistForegroundBrushConverter" />

        <Style x:Key="MediaListItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="MediaGridItemContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="PlaylistRailListItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid Background="Transparent">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ListItemTemplate" x:DataType="viewModels:MediaItemViewModel">
            <Border Padding="10"
                    Background="{ThemeResource MediaCardBrush}"
                    BorderThickness="0"
                    CornerRadius="0">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="ListSelectionOverlay"
                            Background="{ThemeResource SelectionOverlayBrush}"
                            BorderThickness="0"
                            CornerRadius="0"
                            x:Load="{x:Bind IsSelected}" />

                    <Border Width="78"
                            Height="78"
                            Background="{ThemeResource MediaCardPlaceholderBrush}"
                            CornerRadius="0">
                        <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <StackPanel Spacing="3">
                            <TextBlock Text="{x:Bind FileName}"
                                       Foreground="{ThemeResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind SizeText}"
                                           Foreground="{ThemeResource MutedTextBrush}"
                                           FontSize="12" />
                                <TextBlock Text="{x:Bind ResolutionText}"
                                           Foreground="{ThemeResource MutedTextBrush}"
                                           FontSize="12" />
                                <TextBlock Text="{x:Bind DurationText}"
                                           Foreground="{ThemeResource MutedTextBrush}"
                                           FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <Border HorizontalAlignment="Left"
                                Padding="6,3"
                                Background="{ThemeResource MediaTagChipBrush}"
                                CornerRadius="4">
                            <TextBlock Text="{x:Bind TagsText}"
                                       Foreground="{ThemeResource AccentBrush}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="GridItemTemplate" x:DataType="viewModels:MediaItemViewModel">
            <Border Width="{Binding ElementName=GridView, Path=Tag}"
                    Height="{Binding ElementName=GridView, Path=Tag}"
                    Background="{ThemeResource MediaCardBrush}"
                    BorderThickness="0"
                    CornerRadius="0">
                <Grid>
                    <Border x:Name="GridSelectionOverlay"
                            Background="{ThemeResource SelectionOverlayBrush}"
                            BorderThickness="0"
                            CornerRadius="0"
                            x:Load="{x:Bind IsSelected}" />
                    <Border Margin="8"
                            Background="{ThemeResource MediaCardPlaceholderBrush}"
                            CornerRadius="0">
                        <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill" />
                    </Border>

                    <Border Margin="8"
                            VerticalAlignment="Bottom"
                            Background="{StaticResource MediaThumbOverlayBrush}"
                            CornerRadius="0"
                            Padding="10,8">
                        <StackPanel Spacing="3">
                            <TextBlock Text="{x:Bind FileName}"
                                       Foreground="{ThemeResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind SizeText}"
                                           Foreground="{ThemeResource MutedTextBrush}"
                                           FontSize="10" />
                                <TextBlock Text="{x:Bind ResolutionText}"
                                           Foreground="{ThemeResource MutedTextBrush}"
                                           FontSize="10" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind TagsText}"
                                       Foreground="{ThemeResource AccentBrush}"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PlaylistRailTemplate" x:DataType="models:Playlist">
            <Border Width="34"
                    Height="34"
                    Background="{x:Bind ColorHex, Converter={StaticResource PlaylistBackgroundBrushConverter}}"
                    CornerRadius="4"
                    ToolTipService.ToolTip="{x:Bind Name}"
                    RightTapped="PlaylistRailItem_RightTapped">
                <TextBlock Text="{x:Bind RailDisplayText}"
                           Foreground="{x:Bind ColorHex, Converter={StaticResource PlaylistForegroundBrushConverter}}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           MaxLines="1"
                           TextTrimming="Clip" />
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="RootLayout"
          Padding="{ThemeResource PageOuterPadding}">
        <SplitView x:Name="LibrarySplitView"
                   DisplayMode="CompactInline"
                   IsPaneOpen="True"
                   CompactPaneLength="56"
                   OpenPaneLength="360"
                   Background="Transparent">
            <SplitView.Pane>
                <Grid x:Name="LibraryPaneRoot"
                      Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{ThemeResource SurfaceAltBrush}">
                        <Grid Padding="8,10,8,10"
                              RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Button x:Name="MediaTabButton"
                                    Click="MediaTabButton_Click"
                                    Style="{StaticResource PanelIconButtonStyle}"
                                    ToolTipService.ToolTip="媒体库">
                                <FontIcon Glyph="&#xE8B9;" />
                            </Button>

                            <Rectangle Grid.Row="1"
                                       Height="1"
                                       Margin="4,4,4,8"
                                       Fill="{ThemeResource SurfaceStrokeBrush}" />

                            <ListView x:Name="PlaylistRailListView"
                                      Grid.Row="2"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.Playlists, Mode=OneWay}"
                                      ItemContainerStyle="{StaticResource PlaylistRailListItemContainerStyle}"
                                      ItemTemplate="{StaticResource PlaylistRailTemplate}"
                                      SelectionMode="Single"
                                      IsItemClickEnabled="True"
                                      ItemClick="PlaylistRailListView_ItemClick"
                                      CanDragItems="True"
                                      CanReorderItems="True"
                                      AllowDrop="True"
                                      DragItemsCompleted="PlaylistRailListView_DragItemsCompleted"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden" />

                            <Button Grid.Row="3"
                                    x:Name="CreatePlaylistRailButton"
                                    Click="CreatePlaylist_Click"
                                    Style="{StaticResource PanelIconButtonStyle}"
                                    ToolTipService.ToolTip="添加播放列表">
                                <FontIcon Glyph="&#xE710;" />
                            </Button>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource SectionCardStyle}"
                            Padding="12"
                            AllowDrop="True"
                            DragOver="LibraryPanel_DragOver"
                            Drop="LibraryPanel_Drop">
                        <Grid x:Name="LibraryPaneExpandedContent"
                              RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Spacing="8">
                                    <Button x:Name="SelectedPlaylistTitleButton"
                                            Click="SelectedPlaylistTitleButton_Click"
                                            Padding="0"
                                            HorizontalAlignment="Left"
                                            HorizontalContentAlignment="Left"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="0"
                                            Foreground="{ThemeResource TextBrush}"
                                            FontSize="14.3"
                                            FontWeight="SemiBold"
                                            Visibility="Collapsed"
                                            ToolTipService.ToolTip="点击重命名播放列表" />

                                    <StackPanel x:Name="MediaActionsPanel"
                                                Orientation="Horizontal"
                                                Spacing="6">
                                        <Button Click="Refresh_Click"
                                                Style="{StaticResource PanelIconButtonStyle}"
                                                ToolTipService.ToolTip="刷新">
                                            <FontIcon Glyph="&#xE72C;" />
                                        </Button>
                                        <Button x:Name="ViewModeToggleButton"
                                                Click="ToggleViewMode_Click"
                                                Style="{StaticResource PanelIconButtonStyle}"
                                                ToolTipService.ToolTip="切换视图">
                                            <FontIcon Glyph="&#xECA5;" />
                                        </Button>
                                        <Button x:Name="SortButton"
                                                Click="Sort_Click"
                                                Style="{StaticResource PanelIconButtonStyle}"
                                                ToolTipService.ToolTip="排序">
                                            <FontIcon Glyph="&#xE8CB;" />
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <Grid Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      MaxWidth="240">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding StatusMessage}"
                                               Foreground="{ThemeResource MutedTextBrush}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis" />
                                    <ProgressBar x:Name="ScanProgressBar"
                                                 Grid.Row="1"
                                                 Margin="0,6,0,0"
                                                 Height="3"
                                                 Visibility="Collapsed"
                                                 Minimum="0"
                                                 Maximum="{Binding ScanProgressMaximum}"
                                                 Value="{Binding ScanProgressValue}" />
                                    <TextBlock x:Name="ScanPathText"
                                               Grid.Row="2"
                                               Margin="0,4,0,0"
                                               Text="{Binding ScanCurrentPath}"
                                               Foreground="{ThemeResource SubtleTextBrush}"
                                               FontSize="10"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="Collapsed" />
                                </Grid>

                            </Grid>

                            <Grid Grid.Row="1">
                                <TextBox x:Name="SearchBox"
                                         PlaceholderText="搜索媒体或输入 #标签"
                                         Style="{StaticResource GlassTextBoxStyle}"
                                         TextChanged="SearchBox_TextChanged"
                                         KeyDown="SearchBox_KeyDown" />
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid x:Name="MediaContentPanel">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <ItemsControl x:Name="SelectedTagsControl"
                                                  Margin="0,0,0,8"
                                                  Visibility="Collapsed">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Button Click="SelectedTagRemove_Click"
                                                        Tag="{Binding}"
                                                        Margin="0,0,6,6"
                                                        Padding="8,3"
                                                        Background="{ThemeResource FilterChipBrush}"
                                                        Foreground="{ThemeResource AccentBrush}"
                                                        BorderThickness="0"
                                                        CornerRadius="4"
                                                        Content="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapGrid />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>

                                    <Grid Grid.Row="1">
                                        <ListView x:Name="ListView"
                                                  Background="Transparent"
                                                  ItemContainerStyle="{StaticResource MediaListItemContainerStyle}"
                                                  ItemsSource="{Binding FilteredMediaItems}"
                                                  ItemTemplate="{StaticResource ListItemTemplate}"
                                                  IncrementalLoadingTrigger="Edge"
                                                  IncrementalLoadingThreshold="2"
                                                  DataFetchSize="1"
                                                  SelectionMode="Extended"
                                                  IsItemClickEnabled="True"
                                                  ItemClick="Media_ItemClick"
                                                  ContainerContentChanging="Media_ContainerContentChanging"
                                                  SelectionChanged="Media_SelectionChanged"
                                                  RightTapped="MediaView_RightTapped">
                                            <ListView.ItemContainerTransitions>
                                                <TransitionCollection>
                                                    <AddDeleteThemeTransition />
                                                    <RepositionThemeTransition />
                                                </TransitionCollection>
                                            </ListView.ItemContainerTransitions>
                                        </ListView>

                                        <GridView x:Name="GridView"
                                                  Tag="140"
                                                  Visibility="Collapsed"
                                                  Background="Transparent"
                                                  ItemContainerStyle="{StaticResource MediaGridItemContainerStyle}"
                                                  ItemsSource="{Binding FilteredMediaItems}"
                                                  ItemTemplate="{StaticResource GridItemTemplate}"
                                                  IncrementalLoadingTrigger="Edge"
                                                  IncrementalLoadingThreshold="2"
                                                  DataFetchSize="1"
                                                  SelectionMode="Extended"
                                                  IsItemClickEnabled="True"
                                                  ItemClick="Media_ItemClick"
                                                  ContainerContentChanging="Media_ContainerContentChanging"
                                                  SelectionChanged="Media_SelectionChanged"
                                                  RightTapped="MediaView_RightTapped">
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal" ItemWidth="140" ItemHeight="140" />
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>
                                        </GridView>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Thumb x:Name="LibraryPaneResizer"
                           Grid.ColumnSpan="2"
                           Width="8"
                           HorizontalAlignment="Right"
                           Background="{ThemeResource ResizerBrush}"
                           DragStarted="LibraryPaneResizer_DragStarted"
                           DragDelta="LibraryPaneResizer_DragDelta"
                           DragCompleted="LibraryPaneResizer_DragCompleted" />

                </Grid>
            </SplitView.Pane>

            <SplitView.Content>
                <Border Margin="4,0,0,0"
                        Background="{ThemeResource PlayerSurfaceBrush}"
                        BorderThickness="0"
                        CornerRadius="0">
                    <Grid x:Name="PlayerRoot"
                          Background="Transparent"
                          PointerMoved="PlayerRoot_PointerMoved"
                          PointerPressed="PlayerRoot_PointerPressed"
                          PointerExited="PlayerRoot_PointerExited">
                        <Rectangle Fill="{ThemeResource WindowAmbientBrush}"
                                   IsHitTestVisible="False" />

                        <Grid x:Name="EmptyState"
                              Visibility="Visible">
                            <Border HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Padding="24"
                                    Background="{ThemeResource EmptyStateCardBrush}"
                                    BorderThickness="0"
                                    CornerRadius="0">
                                <StackPanel HorizontalAlignment="Center"
                                            Spacing="6">
                                    <Border Width="56"
                                            Height="56"
                                            Background="{ThemeResource EmptyStateIconBrush}"
                                            CornerRadius="0"
                                            HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE8B9;"
                                                  FontSize="24"
                                                  Foreground="{ThemeResource AccentBrush}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="选择媒体"
                                               Foreground="{ThemeResource TextBrush}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="从左侧导入、搜索并浏览媒体。"
                                               Foreground="{ThemeResource MutedTextBrush}"
                                               FontSize="13"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="PageUp / PageDown 切换上一个或下一个"
                                               Foreground="{ThemeResource SubtleTextBrush}"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <MediaPlayerElement x:Name="VideoPlayer"
                                            AreTransportControlsEnabled="False"
                                            AutoPlay="True"
                                            Visibility="Collapsed"
                                            Stretch="Uniform" />

                        <ScrollViewer x:Name="ImageScrollViewer"
                                      Visibility="Collapsed"
                                      ZoomMode="Enabled"
                                      HorizontalScrollMode="Enabled"
                                      VerticalScrollMode="Enabled"
                                      MinZoomFactor="1"
                                      MaxZoomFactor="6">
                            <Border HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Image x:Name="PreviewImageElement"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       ImageOpened="PreviewImageElement_ImageOpened" />
                            </Border>
                        </ScrollViewer>

                        <Grid x:Name="PlayerOverlay">
                            <Border x:Name="PlayerInfoBadge"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="16"
                                    Padding="10,8"
                                    Background="{ThemeResource PlayerInfoBrush}"
                                    BorderThickness="0"
                                    CornerRadius="0"
                                    IsHitTestVisible="False">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding SelectedMedia.FileName}"
                                               Foreground="{ThemeResource TextBrush}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SelectedMedia.ResolutionText}"
                                               Foreground="{ThemeResource MutedTextBrush}"
                                               FontSize="12" />
                                </StackPanel>
                            </Border>

                            <Grid>
                                <Border x:Name="PreviousMediaHotspot"
                                        HorizontalAlignment="Left"
                                        Width="96"
                                        Background="Transparent"
                                        Visibility="Collapsed"
                                        PointerEntered="PreviousMediaHotspot_PointerEntered"
                                        Tapped="PreviousMediaHotspot_Tapped">
                                    <Grid>
                                        <Border x:Name="PreviousMediaCue"
                                                Width="22"
                                                Height="56"
                                                Margin="8,0,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource PlayerEdgeNavigationButtonBrush}"
                                                BorderThickness="0"
                                                CornerRadius="6"
                                                Opacity="0"
                                                IsHitTestVisible="False">
                                            <FontIcon Glyph="&#xE76B;"
                                                      FontSize="12"
                                                      Foreground="{ThemeResource TextBrush}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border x:Name="NextMediaHotspot"
                                        HorizontalAlignment="Right"
                                        Width="96"
                                        Background="Transparent"
                                        Visibility="Collapsed"
                                        PointerEntered="NextMediaHotspot_PointerEntered"
                                        Tapped="NextMediaHotspot_Tapped">
                                    <Grid>
                                        <Border x:Name="NextMediaCue"
                                                Width="22"
                                                Height="56"
                                                Margin="0,0,8,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource PlayerEdgeNavigationButtonBrush}"
                                                BorderThickness="0"
                                                CornerRadius="6"
                                                Opacity="0"
                                                IsHitTestVisible="False">
                                            <FontIcon Glyph="&#xE76C;"
                                                      FontSize="12"
                                                      Foreground="{ThemeResource TextBrush}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border x:Name="ImageZoomBadge"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="16"
                                    Padding="10,5"
                                    Background="{ThemeResource ZoomBadgeBrush}"
                                    BorderThickness="0"
                                    CornerRadius="0"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False">
                                <TextBlock x:Name="ImageZoomText"
                                           Text="100%"
                                           Foreground="{ThemeResource TextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>

                            <Border x:Name="ControlBar"
                                    VerticalAlignment="Bottom"
                                    Margin="16"
                                    Padding="12"
                                    Background="{ThemeResource ControlBarBrush}"
                                    BorderThickness="0"
                                    CornerRadius="0"
                                    PointerMoved="ControlBar_PointerMoved">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Slider x:Name="ProgressSlider"
                                            Grid.Row="0"
                                            Minimum="0"
                                            Maximum="1"
                                            Value="0"
                                            SmallChange="1"
                                            LargeChange="10"
                                            ValueChanged="ProgressSlider_ValueChanged" />

                                    <Grid Grid.Row="1"
                                          ColumnSpacing="10"
                                          Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <AppBarButton x:Name="PlayPauseButton"
                                                      Grid.Column="0"
                                                      Click="PlayPause_Click"
                                                      ToolTipService.ToolTip="播放 / 暂停">
                                            <AppBarButton.Icon>
                                                <FontIcon Glyph="&#xE768;" />
                                            </AppBarButton.Icon>
                                        </AppBarButton>

                                        <Border Grid.Column="1"
                                                Padding="8,4"
                                                Background="{ThemeResource PlayerInfoBrush}"
                                                BorderThickness="0"
                                                CornerRadius="4"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="4">
                                                <TextBlock x:Name="CurrentTimeText"
                                                           Text="0:00"
                                                           Foreground="{ThemeResource TextBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="/"
                                                           Foreground="{ThemeResource MutedTextBrush}"
                                                           FontSize="12" />
                                                <TextBlock x:Name="TotalTimeText"
                                                           Text="0:00"
                                                           Foreground="{ThemeResource MutedTextBrush}"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">
                                            <Button x:Name="VolumeButton"
                                                    Click="VolumeButton_Click"
                                                    Style="{StaticResource PanelIconButtonStyle}"
                                                    ToolTipService.ToolTip="音量">
                                                <FontIcon Glyph="&#xE767;" />
                                            </Button>
                                            <Slider x:Name="VolumeSlider"
                                                    Width="110"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    Value="0.8"
                                                    ValueChanged="VolumeSlider_ValueChanged" />
                                        </StackPanel>

                                        <Button x:Name="PlaybackModeButton"
                                                Grid.Column="4"
                                                Click="PlaybackMode_Click"
                                                Style="{StaticResource PanelIconButtonStyle}"
                                                ToolTipService.ToolTip="播放模式">
                                            <FontIcon Glyph="&#xE8EE;" />
                                        </Button>
                                        <Button x:Name="ClipModeToggleButton"
                                                Grid.Column="5"
                                                Click="ToggleClipMode_Click"
                                                Style="{StaticResource PanelIconButtonStyle}"
                                                ToolTipService.ToolTip="进入剪辑">
                                            <FontIcon Glyph="&#xE7C8;" />
                                        </Button>
                                        <Button x:Name="FullScreenButton"
                                                Grid.Column="6"
                                                Click="FullScreen_Click"
                                                Style="{StaticResource PanelIconButtonStyle}"
                                                ToolTipService.ToolTip="全屏">
                                            <FontIcon Glyph="&#xE740;" />
                                        </Button>
                                    </Grid>

                                    <Border x:Name="ClipBar"
                                            Grid.Row="2"
                                            Margin="0,10,0,0"
                                            Padding="10"
                                            Background="{ThemeResource ClipBarBrush}"
                                            BorderThickness="0"
                                            CornerRadius="0"
                                            Visibility="Collapsed">
                                        <StackPanel Spacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Button x:Name="SetClipStartButton"
                                                        Click="SetClipStart_Click"
                                                        Style="{StaticResource PanelIconButtonStyle}"
                                                        ToolTipService.ToolTip="标记入点 (I)">
                                                    <FontIcon Glyph="&#xE7C1;" />
                                                </Button>
                                                <Button x:Name="SetClipEndButton"
                                                        Click="SetClipEnd_Click"
                                                        Style="{StaticResource PanelIconButtonStyle}"
                                                        ToolTipService.ToolTip="标记出点 (O)">
                                                    <FontIcon Glyph="&#xE7C5;" />
                                                </Button>
                                                <Button x:Name="ClipPlanButton"
                                                        Click="ClipPlan_Click"
                                                        Style="{StaticResource PanelIconButtonStyle}"
                                                        ToolTipService.ToolTip="片段方案">
                                                    <FontIcon Glyph="&#xE8A5;" />
                                                </Button>
                                                <Button x:Name="ClearClipButton"
                                                        Click="ClearClip_Click"
                                                        Style="{StaticResource PanelIconButtonStyle}"
                                                        ToolTipService.ToolTip="重置区间">
                                                    <FontIcon Glyph="&#xE894;" />
                                                </Button>
                                                <Button x:Name="ExportClipButton"
                                                        Click="ExportClip_Click"
                                                        Style="{StaticResource PrimaryIconButtonStyle}"
                                                        ToolTipService.ToolTip="导出剪辑 (E)">
                                                    <FontIcon Glyph="&#xEDE1;" />
                                                </Button>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Padding="8,4"
                                                        Background="{ThemeResource PlayerInfoBrush}"
                                                        BorderThickness="0"
                                                        CornerRadius="4">
                                                    <TextBlock x:Name="ClipStartText"
                                                               Text="入点：0:00"
                                                               Foreground="{ThemeResource TextBrush}"
                                                               FontSize="12" />
                                                </Border>
                                                <Border Padding="8,4"
                                                        Background="{ThemeResource PlayerInfoBrush}"
                                                        BorderThickness="0"
                                                        CornerRadius="4">
                                                    <TextBlock x:Name="ClipEndText"
                                                               Text="出点：0:00"
                                                               Foreground="{ThemeResource TextBrush}"
                                                               FontSize="12" />
                                                </Border>
                                                <Border Padding="8,4"
                                                        Background="{ThemeResource PlayerInfoBrush}"
                                                        BorderThickness="0"
                                                        CornerRadius="4">
                                                    <TextBlock x:Name="ClipDurationText"
                                                               Text="时长：0:00"
                                                               Foreground="{ThemeResource TextBrush}"
                                                               FontSize="12" />
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Padding="8,4"
                                                        Background="{ThemeResource ScopeBadgeBrush}"
                                                        BorderThickness="0"
                                                        CornerRadius="4">
                                                    <TextBlock x:Name="ClipModeText"
                                                               Text="模式：保留片段"
                                                               Foreground="{ThemeResource TextBrush}"
                                                               FontSize="12" />
                                                </Border>
                                                <Border Padding="8,4"
                                                        Background="{ThemeResource StatusBadgeBrush}"
                                                        BorderThickness="0"
                                                        CornerRadius="4">
                                                    <TextBlock x:Name="ClipSegmentCountText"
                                                               Text="片段：1"
                                                               Foreground="{ThemeResource TextBrush}"
                                                               FontSize="12" />
                                                </Border>
                                                <Border Padding="8,4"
                                                        Background="{ThemeResource StatusBadgeBrush}"
                                                        BorderThickness="0"
                                                        CornerRadius="4"
                                                        MaxWidth="220">
                                                    <TextBlock x:Name="ClipOutputText"
                                                               Text="输出：原目录"
                                                               Foreground="{ThemeResource TextBrush}"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12"
                                                        VerticalAlignment="Center">
                                                <ProgressBar x:Name="ClipExportProgressBar"
                                                             Width="180"
                                                             Minimum="0"
                                                             Maximum="100"
                                                             Value="0"
                                                             Visibility="Collapsed" />
                                                <TextBlock x:Name="ClipStatusText"
                                                           Foreground="{ThemeResource MutedTextBrush}"
                                                           FontSize="12"
                                                           TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Page>
