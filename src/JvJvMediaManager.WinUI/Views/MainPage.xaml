<Page
    x:Class="JvJvMediaManager.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JvJvMediaManager.Models"
    xmlns:viewModels="using:JvJvMediaManager.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource SurfaceBrush}">

    <Page.Resources>
        <DataTemplate x:Key="ListItemTemplate" x:DataType="viewModels:MediaItemViewModel">
            <Grid Padding="8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="72" Height="48" Background="#2D2D2D" CornerRadius="6">
                    <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="{x:Bind FileName}" Foreground="{ThemeResource TextBrush}" FontSize="14" TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{x:Bind SizeText}" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind ResolutionText}" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                        <TextBlock Text="{x:Bind DurationText}" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind TagsText}" Foreground="#60CDFF" FontSize="11" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="GridItemTemplate" x:DataType="viewModels:MediaItemViewModel">
            <Grid Width="{Binding ElementName=GridView, Path=Tag}" Height="{Binding ElementName=GridView, Path=Tag}">
                <Border CornerRadius="8" Background="#2D2D2D">
                    <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill" />
                </Border>
                <Border Background="#99000000" VerticalAlignment="Bottom" CornerRadius="0,0,8,8" Padding="6">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{x:Bind FileName}" Foreground="{ThemeResource TextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{x:Bind SizeText}" Foreground="{ThemeResource MutedTextBrush}" FontSize="10" />
                        <TextBlock Text="{x:Bind TagsText}" Foreground="#60CDFF" FontSize="10" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PlaylistTemplate" x:DataType="models:Playlist">
            <Grid Padding="8,6">
                <TextBlock Text="{x:Bind Name}" Foreground="{ThemeResource TextBrush}" TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" Background="{ThemeResource SurfaceAltBrush}" DefaultLabelPosition="Collapsed">
            <AppBarButton Icon="Add" Label="添加文件" Click="AddFiles_Click" />
            <AppBarButton Icon="Folder" Label="添加文件夹" Click="AddFolder_Click" />
            <AppBarButton Icon="Sync" Label="刷新" Click="Refresh_Click" />
            <AppBarSeparator />
            <AppBarButton Icon="Tag" Label="编辑标签" Click="EditTags_Click" />
            <AppBarButton Icon="Library" Label="加入播放列表" Click="AddToPlaylist_Click" />
            <AppBarButton Label="锁定管理" Click="FolderLock_Click" />
            <AppBarSeparator />
            <AppBarButton Icon="Setting" Label="设置" Click="Settings_Click" />
        </CommandBar>

        <SplitView Grid.Row="1" DisplayMode="Inline" IsPaneOpen="True" OpenPaneLength="420" Background="{ThemeResource SurfaceBrush}">
            <SplitView.Pane>
                <Grid Background="{ThemeResource SurfaceAltBrush}" AllowDrop="True" DragOver="LibraryPanel_DragOver" Drop="LibraryPanel_Drop">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Padding="12" Spacing="8">
                        <TextBox x:Name="SearchBox"
                                 PlaceholderText="搜索文件名或输入 #标签"
                                 TextChanged="SearchBox_TextChanged"
                                 KeyDown="SearchBox_KeyDown" />
                        <TextBlock Text="{Binding CurrentScopeTitle}" Foreground="{ThemeResource TextBrush}" FontSize="13" FontWeight="SemiBold" />
                        <ItemsControl x:Name="SelectedTagsControl" Visibility="Collapsed">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Button Click="SelectedTagRemove_Click"
                                            Tag="{Binding}"
                                            Margin="0,0,6,6"
                                            Padding="8,3"
                                            Background="#1F005FB8"
                                            Foreground="#60CDFF"
                                            BorderThickness="0"
                                            CornerRadius="6"
                                            Content="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Padding="12,0,12,12" Spacing="6">
                        <ProgressBar x:Name="ScanProgressBar"
                                     Minimum="0"
                                     Maximum="{Binding ScanProgressMaximum}"
                                     Value="{Binding ScanProgressValue}" />
                        <TextBlock x:Name="ScanPathText"
                                   Text="{Binding ScanCurrentPath}"
                                   Foreground="{ThemeResource MutedTextBrush}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="{Binding StatusMessage}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Padding="12,0,12,12" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="全部媒体" Click="AllMedia_Click" />
                            <Button Content="新建列表" Click="CreatePlaylist_Click" />
                            <Button Content="重命名" Click="RenamePlaylist_Click" />
                            <Button Content="删除" Click="DeletePlaylist_Click" />
                        </StackPanel>
                        <ListView x:Name="PlaylistListView"
                                  ItemsSource="{Binding Playlists}"
                                  ItemTemplate="{StaticResource PlaylistTemplate}"
                                  SelectionMode="Single"
                                  MaxHeight="164"
                                  SelectionChanged="PlaylistListView_SelectionChanged"
                                  CanDragItems="True"
                                  CanReorderItems="True"
                                  AllowDrop="True"
                                  DragItemsCompleted="PlaylistListView_DragItemsCompleted" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Padding="12,0,12,12" Spacing="8">
                        <Button Content="列表" Click="ListViewMode_Click" />
                        <Button Content="网格" Click="GridViewMode_Click" />
                        <Button Content="排序" Click="Sort_Click" />
                    </StackPanel>

                    <Grid Grid.Row="4">
                        <ListView x:Name="ListView"
                                  ItemsSource="{Binding FilteredMediaItems}"
                                  ItemTemplate="{StaticResource ListItemTemplate}"
                                  IncrementalLoadingTrigger="Edge"
                                  IncrementalLoadingThreshold="2"
                                  DataFetchSize="1"
                                  SelectionMode="Extended"
                                  IsItemClickEnabled="True"
                                  ItemClick="Media_ItemClick"
                                  ContainerContentChanging="Media_ContainerContentChanging"
                                  SelectionChanged="Media_SelectionChanged"
                                  RightTapped="MediaView_RightTapped" />

                        <GridView x:Name="GridView"
                                  Tag="140"
                                  Visibility="Collapsed"
                                  ItemsSource="{Binding FilteredMediaItems}"
                                  ItemTemplate="{StaticResource GridItemTemplate}"
                                  IncrementalLoadingTrigger="Edge"
                                  IncrementalLoadingThreshold="2"
                                  DataFetchSize="1"
                                  SelectionMode="Extended"
                                  IsItemClickEnabled="True"
                                  ItemClick="Media_ItemClick"
                                  ContainerContentChanging="Media_ContainerContentChanging"
                                  SelectionChanged="Media_SelectionChanged"
                                  RightTapped="MediaView_RightTapped"
                                  PointerWheelChanged="GridView_PointerWheelChanged">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid ItemWidth="140" ItemHeight="140" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                        </GridView>
                    </Grid>
                </Grid>
            </SplitView.Pane>

            <SplitView.Content>
                <Grid x:Name="PlayerRoot" Background="#202020" PointerMoved="PlayerRoot_PointerMoved" PointerPressed="PlayerRoot_PointerPressed" PointerExited="PlayerRoot_PointerExited">
                    <Grid x:Name="EmptyState" Visibility="Visible">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                            <TextBlock Text="选择一个媒体文件开始播放" Foreground="{ThemeResource TextBrush}" FontSize="18" />
                            <TextBlock Text="拖拽文件或文件夹到左侧即可导入" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                            <TextBlock Text="PageUp / PageDown 切换上一个/下一个" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>

                    <MediaPlayerElement x:Name="VideoPlayer" AreTransportControlsEnabled="False" AutoPlay="True" Visibility="Collapsed" Stretch="Uniform" />
                    <ScrollViewer x:Name="ImageScrollViewer"
                                  Visibility="Collapsed"
                                  ZoomMode="Enabled"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollMode="Enabled"
                                  MinZoomFactor="0.2"
                                  MaxZoomFactor="6"
                                  PointerWheelChanged="ImageScrollViewer_PointerWheelChanged">
                        <Image x:Name="ImageViewer" Stretch="Uniform" />
                    </ScrollViewer>

                    <Grid x:Name="PlayerOverlay" Background="Transparent">
                        <Grid x:Name="ControlBar"
                              VerticalAlignment="Bottom"
                              Margin="16"
                              Padding="12"
                              Background="#99000000"
                              CornerRadius="10"
                              PointerMoved="ControlBar_PointerMoved">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Slider x:Name="ProgressSlider"
                                    Grid.Row="0"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="0"
                                    SmallChange="1"
                                    LargeChange="10"
                                    ValueChanged="ProgressSlider_ValueChanged"
                                    PointerPressed="ProgressSlider_PointerPressed"
                                    PointerReleased="ProgressSlider_PointerReleased" />

                            <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <AppBarButton x:Name="PlayPauseButton" Grid.Column="0" Click="PlayPause_Click">
                                    <AppBarButton.Icon>
                                        <SymbolIcon x:Name="PlayPauseIcon" Symbol="Play" />
                                    </AppBarButton.Icon>
                                </AppBarButton>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock x:Name="CurrentTimeText" Text="0:00" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                    <TextBlock Text="/" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                                    <TextBlock x:Name="TotalTimeText" Text="0:00" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                                </StackPanel>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="音量" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                                    <Slider x:Name="VolumeSlider" Width="110" Minimum="0" Maximum="1" Value="0.8" ValueChanged="VolumeSlider_ValueChanged" />
                                </StackPanel>

                                <Button x:Name="PlaybackModeButton" Grid.Column="4" Content="列表循环" Click="PlaybackMode_Click" />
                                <Button x:Name="FullScreenButton" Grid.Column="5" Content="全屏" Click="FullScreen_Click" />
                            </Grid>

                            <Border x:Name="ClipBar"
                                    Grid.Row="2"
                                    Margin="0,10,0,0"
                                    Padding="10,8"
                                    Background="#55000000"
                                    CornerRadius="8"
                                    Visibility="Collapsed">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="SetClipStartButton" Content="标记入点 (I)" Click="SetClipStart_Click" />
                                        <Button x:Name="SetClipEndButton" Content="标记出点 (O)" Click="SetClipEnd_Click" />
                                        <Button x:Name="ClipPlanButton" Content="片段方案..." Click="ClipPlan_Click" />
                                        <Button x:Name="ClearClipButton" Content="重置区间" Click="ClearClip_Click" />
                                        <Button x:Name="ExportClipButton" Content="导出剪辑 (E)" Click="ExportClip_Click" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <TextBlock x:Name="ClipStartText" Text="入点：0:00" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                        <TextBlock x:Name="ClipEndText" Text="出点：0:00" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                        <TextBlock x:Name="ClipDurationText" Text="时长：0:00" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <TextBlock x:Name="ClipModeText" Text="模式：保留片段" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                        <TextBlock x:Name="ClipSegmentCountText" Text="片段：1" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                        <TextBlock x:Name="ClipOutputText" Text="输出：原目录" Foreground="{ThemeResource TextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <ProgressBar x:Name="ClipExportProgressBar"
                                                     Width="180"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="0"
                                                     Visibility="Collapsed" />
                                        <TextBlock x:Name="ClipStatusText"
                                                   Foreground="{ThemeResource MutedTextBrush}"
                                                   FontSize="12"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Page>
