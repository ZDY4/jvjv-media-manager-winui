<Page
    x:Class="JvJvMediaManager.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mainPage="using:JvJvMediaManager.Views.MainPageParts"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Space" Invoked="PlayPauseKeyboardAccelerator_Invoked" />
        <KeyboardAccelerator Key="Delete" Invoked="DeleteKeyboardAccelerator_Invoked" />
    </Page.KeyboardAccelerators>

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid x:Name="RootLayoutHost"
          Padding="{ThemeResource PageOuterPadding}">
        <Rectangle Fill="{ThemeResource HeroPanelBrush}"
                   IsHitTestVisible="False" />
        <SplitView x:Name="LibrarySplitViewHost"
                   DisplayMode="CompactInline"
                   IsPaneOpen="{Binding Library.IsLibraryPaneOpen, Mode=TwoWay}"
                   CompactPaneLength="56"
                   OpenPaneLength="{Binding Library.LibraryPaneWidth, Mode=TwoWay}"
                   Background="Transparent">
            <SplitView.Pane>
                <mainPage:LibraryPaneView x:Name="LibraryPaneHost"
                                          DataContext="{Binding Library}" />
            </SplitView.Pane>

            <SplitView.Content>
                <mainPage:PlayerPaneView x:Name="PlayerPaneHost"
                                         DataContext="{Binding Player}" />
            </SplitView.Content>
        </SplitView>
    </Grid>
</Page>
