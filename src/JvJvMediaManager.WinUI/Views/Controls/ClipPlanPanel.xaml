<UserControl
    x:Class="JvJvMediaManager.Views.Controls.ClipPlanPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer MaxHeight="560"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="SourceDurationText"
                               x:FieldModifier="public"
                               Foreground="{ThemeResource MutedTextBrush}" />

                    <ComboBox x:Name="ModeComboBox"
                              x:FieldModifier="public"
                              Style="{StaticResource GlassComboBoxStyle}" />

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="StartBox"
                                 x:FieldModifier="public"
                                 Grid.Column="0"
                                 PlaceholderText="开始时间，如 00:01:23.500"
                                 Style="{StaticResource GlassTextBoxStyle}" />

                        <TextBox x:Name="EndBox"
                                 x:FieldModifier="public"
                                 Grid.Column="1"
                                 PlaceholderText="结束时间，如 00:02:10.000"
                                 Style="{StaticResource GlassTextBoxStyle}" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="UseCurrentButton"
                                x:FieldModifier="public"
                                Content="使用当前入/出点"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        <Button x:Name="AddButton"
                                x:FieldModifier="public"
                                Content="添加片段"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        <Button x:Name="RemoveButton"
                                x:FieldModifier="public"
                                Content="移除选中"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        <Button x:Name="ClearButton"
                                x:FieldModifier="public"
                                Content="清空片段"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GlassPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="片段列表"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <ListView x:Name="SegmentsListView"
                              x:FieldModifier="public"
                              MaxHeight="220"
                              SelectionMode="Single" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="输出目录"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="OutputDirBox"
                                 x:FieldModifier="public"
                                 Grid.Column="0"
                                 PlaceholderText="输出目录"
                                 Style="{StaticResource GlassTextBoxStyle}" />

                        <Button x:Name="PickOutputButton"
                                x:FieldModifier="public"
                                Grid.Column="1"
                                Content="选择输出目录"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                    </Grid>

                    <TextBlock x:Name="SummaryText"
                               x:FieldModifier="public"
                               Foreground="{ThemeResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
