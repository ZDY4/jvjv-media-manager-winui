<UserControl
    x:Class="JvJvMediaManager.Views.Controls.TagEditorPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="16">
        <Border Style="{StaticResource SectionCardStyle}">
            <StackPanel Spacing="12">
                <TextBlock x:Name="DescriptionText"
                           Foreground="{ThemeResource TextBrush}"
                           FontSize="14"
                           TextWrapping="Wrap" />

                <ComboBox x:Name="ModeComboBox"
                          x:FieldModifier="public"
                          Style="{StaticResource GlassComboBoxStyle}"
                          Visibility="Collapsed" />

                <TextBox x:Name="TagTextBox"
                         x:FieldModifier="public"
                         AcceptsReturn="True"
                         MinHeight="140"
                         TextWrapping="Wrap"
                         PlaceholderText="输入标签，支持逗号、分号或换行分隔"
                         Style="{StaticResource GlassTextBoxStyle}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
