<UserControl
    x:Class="JvJvMediaManager.Views.Controls.SettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="WatchedFolderTemplate">
            <Border
                Margin="0,0,0,8"
                Padding="12,10"
                Background="{ThemeResource PlaylistItemBrush}"
                BorderBrush="{ThemeResource SurfaceStrokeBrush}"
                BorderThickness="1"
                CornerRadius="14">
                <Grid>
                    <TextBlock Text="{Binding Path}"
                               Foreground="{ThemeResource TextBrush}"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer MaxHeight="560"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="外观、存储与运行方式"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <ToggleSwitch x:Name="PortableToggle"
                                  x:FieldModifier="public"
                                  Header="便携模式（数据保存在程序目录 data）" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="数据目录"
                                   Foreground="{ThemeResource MutedTextBrush}" />
                        <TextBox x:Name="DataDirTextBox"
                                 x:FieldModifier="public"
                                 PlaceholderText="留空时使用默认目录"
                                 Style="{StaticResource GlassTextBoxStyle}" />
                        <Button x:Name="ChooseDataDirButton"
                                x:FieldModifier="public"
                                Content="选择数据目录"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GlassPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="安全与锁定"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <PasswordBox x:Name="GlobalPasswordBox"
                                 x:FieldModifier="public"
                                 PlaceholderText="为受保护文件夹设置全局密码"
                                 Style="{StaticResource GlassPasswordBoxStyle}" />

                    <TextBlock x:Name="ValidationText"
                               x:FieldModifier="public"
                               Foreground="{ThemeResource WarningBrush}"
                               TextWrapping="Wrap" />

                    <TextBlock x:Name="WatchedFolderStatusText"
                               x:FieldModifier="public"
                               Foreground="{ThemeResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="监控文件夹"
                                   Foreground="{ThemeResource TextBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />

                        <Button x:Name="AddWatchedFolderButton"
                                x:FieldModifier="public"
                                Grid.Column="1"
                                Content="添加监控文件夹"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                    </Grid>

                    <ListView x:Name="WatchedFoldersList"
                              x:FieldModifier="public"
                              MaxHeight="240"
                              SelectionMode="Single"
                              ItemTemplate="{StaticResource WatchedFolderTemplate}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="RemoveWatchedFolderButton"
                                x:FieldModifier="public"
                                Content="移除选中"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        <Button x:Name="ClearWatchedFoldersButton"
                                x:FieldModifier="public"
                                Content="清空监控列表"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        <Button x:Name="ProtectFolderButton"
                                x:FieldModifier="public"
                                Content="设为受保护"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        <Button x:Name="UnprotectFolderButton"
                                x:FieldModifier="public"
                                Content="取消保护"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GlassPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="维护操作"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ClearCacheButton"
                                x:FieldModifier="public"
                                Content="清理缩略图缓存"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        <Button x:Name="ResetLibraryButton"
                                x:FieldModifier="public"
                                Content="清理缓存并重置库"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        <Button x:Name="ClearAllButton"
                                x:FieldModifier="public"
                                Content="清理全部应用数据"
                                Style="{StaticResource PrimaryToolbarButtonStyle}" />
                    </StackPanel>

                    <TextBlock Text="修改数据目录或便携模式后，建议重启应用以切换到新的数据库位置。受保护文件夹需要在“锁定管理”里输入密码后才会显示媒体。"
                               Foreground="{ThemeResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
