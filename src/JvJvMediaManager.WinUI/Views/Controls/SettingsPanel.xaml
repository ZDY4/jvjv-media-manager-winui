<UserControl
    x:Class="JvJvMediaManager.Views.Controls.SettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="WatchedFolderListItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid Background="Transparent">
                            <Border x:Name="SelectionChrome"
                                    Margin="0,0,0,8"
                                    Background="{ThemeResource LibrarySelectionBrush}"
                                    CornerRadius="{ThemeResource RadiusMedium}"
                                    Opacity="0"
                                    IsHitTestVisible="False" />
                            <ContentPresenter x:Name="ContentPresenter"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="SelectionChrome.Opacity" Value="0.45" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="SelectionChrome.Opacity" Value="0.7" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="ContentPresenter.Opacity" Value="0.42" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="SelectionStates">
                                    <VisualState x:Name="Unselected" />
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="SelectionChrome.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="SelectedUnfocused">
                                        <VisualState.Setters>
                                            <Setter Target="SelectionChrome.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="WatchedFolderTemplate">
            <Border
                Margin="0,0,0,8"
                Padding="12,10"
                Background="{ThemeResource SurfaceAltBrush}"
                BorderBrush="{ThemeResource SurfaceStrokeBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource RadiusMedium}">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding Path}"
                               Foreground="{ThemeResource TextBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <ToggleButton Grid.Column="1"
                                  Width="30"
                                  Height="30"
                                  Padding="6"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding Visible, Mode=TwoWay}"
                                  Click="ToggleWatchedFolderVisibilityButton_Click"
                                  Loaded="ToggleWatchedFolderVisibilityButton_Loaded"
                                  Tag="{Binding}">
                        <FontIcon FontSize="12"
                                  FontFamily="Segoe MDL2 Assets" />
                    </ToggleButton>

                    <ToggleButton Grid.Column="2"
                                  Width="30"
                                  Height="30"
                                  Padding="6"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding Locked, Mode=TwoWay}"
                                  Click="ToggleWatchedFolderLockedButton_Click"
                                  Loaded="ToggleWatchedFolderLockedButton_Loaded"
                                  Tag="{Binding}">
                        <FontIcon FontSize="12"
                                  FontFamily="Segoe MDL2 Assets" />
                    </ToggleButton>

                    <Button Grid.Column="3"
                            Width="30"
                            Height="30"
                            Padding="6"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            Click="RemoveWatchedFolderItemButton_Click"
                            Tag="{Binding}"
                            ToolTipService.ToolTip="删除这个监控文件夹">
                        <FontIcon Glyph="&#xE711;"
                                  FontSize="12"
                                  FontFamily="Segoe MDL2 Assets" />
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer MaxHeight="560"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="存储与运行方式"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <ToggleSwitch x:Name="PortableToggle"
                                  x:FieldModifier="public"
                                  Header="便携模式（默认开启）"
                                  ToolTipService.ToolTip="开启后，数据库、配置和缓存会固定保存在程序目录下的 data 文件夹里，适合跟随整个软件文件夹一起移动。关闭后，应用才会使用下方的数据目录设置。切换后建议重启应用。" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="数据目录"
                                   Foreground="{ThemeResource MutedTextBrush}" />
                        <TextBox x:Name="DataDirTextBox"
                                 x:FieldModifier="public"
                                 PlaceholderText="留空时使用默认目录"
                                 Style="{StaticResource GlassTextBoxStyle}" />
                        <Button x:Name="ChooseDataDirButton"
                                x:FieldModifier="public"
                                Content="选择数据目录"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GlassPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="安全与锁定"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <PasswordBox x:Name="GlobalPasswordBox"
                                 x:FieldModifier="public"
                                 PlaceholderText="为受保护文件夹设置全局密码"
                                 Style="{StaticResource GlassPasswordBoxStyle}" />

                    <TextBlock x:Name="ValidationText"
                               x:FieldModifier="public"
                               Foreground="{ThemeResource WarningBrush}"
                               TextWrapping="Wrap" />

                    <TextBlock x:Name="WatchedFolderStatusText"
                               x:FieldModifier="public"
                               Foreground="{ThemeResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="监控文件夹"
                                   Foreground="{ThemeResource TextBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />

                        <Button x:Name="AddWatchedFolderButton"
                                x:FieldModifier="public"
                                Grid.Column="1"
                                Content="添加"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />

                        <Button x:Name="ClearWatchedFoldersButton"
                                x:FieldModifier="public"
                                Grid.Column="2"
                                Content="清空"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                    </Grid>

                    <ListView x:Name="WatchedFoldersList"
                              x:FieldModifier="public"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectionMode="Single"
                              ScrollViewer.HorizontalScrollMode="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              ScrollViewer.VerticalScrollMode="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              ItemContainerStyle="{StaticResource WatchedFolderListItemContainerStyle}"
                              ItemTemplate="{StaticResource WatchedFolderTemplate}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="快捷标签"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <TextBlock Text="设置后，可在播放器中按小键盘 1-9，或点击左下角提示，为当前播放/预览的媒体追加对应标签。留空表示不启用该数字。"
                               Foreground="{ThemeResource MutedTextBrush}"
                               TextWrapping="Wrap" />

                    <Grid ColumnSpacing="12"
                          RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                            <TextBlock Text="小键盘 1"
                                       Foreground="{ThemeResource MutedTextBrush}" />
                            <TextBox x:Name="NumpadTag1TextBox"
                                     PlaceholderText="未设置"
                                     Style="{StaticResource GlassTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                            <TextBlock Text="小键盘 2"
                                       Foreground="{ThemeResource MutedTextBrush}" />
                            <TextBox x:Name="NumpadTag2TextBox"
                                     PlaceholderText="未设置"
                                     Style="{StaticResource GlassTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Spacing="6">
                            <TextBlock Text="小键盘 3"
                                       Foreground="{ThemeResource MutedTextBrush}" />
                            <TextBox x:Name="NumpadTag3TextBox"
                                     PlaceholderText="未设置"
                                     Style="{StaticResource GlassTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                            <TextBlock Text="小键盘 4"
                                       Foreground="{ThemeResource MutedTextBrush}" />
                            <TextBox x:Name="NumpadTag4TextBox"
                                     PlaceholderText="未设置"
                                     Style="{StaticResource GlassTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                            <TextBlock Text="小键盘 5"
                                       Foreground="{ThemeResource MutedTextBrush}" />
                            <TextBox x:Name="NumpadTag5TextBox"
                                     PlaceholderText="未设置"
                                     Style="{StaticResource GlassTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Spacing="6">
                            <TextBlock Text="小键盘 6"
                                       Foreground="{ThemeResource MutedTextBrush}" />
                            <TextBox x:Name="NumpadTag6TextBox"
                                     PlaceholderText="未设置"
                                     Style="{StaticResource GlassTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="6">
                            <TextBlock Text="小键盘 7"
                                       Foreground="{ThemeResource MutedTextBrush}" />
                            <TextBox x:Name="NumpadTag7TextBox"
                                     PlaceholderText="未设置"
                                     Style="{StaticResource GlassTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Spacing="6">
                            <TextBlock Text="小键盘 8"
                                       Foreground="{ThemeResource MutedTextBrush}" />
                            <TextBox x:Name="NumpadTag8TextBox"
                                     PlaceholderText="未设置"
                                     Style="{StaticResource GlassTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2" Spacing="6">
                            <TextBlock Text="小键盘 9"
                                       Foreground="{ThemeResource MutedTextBrush}" />
                            <TextBox x:Name="NumpadTag9TextBox"
                                     PlaceholderText="未设置"
                                     Style="{StaticResource GlassTextBoxStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GlassPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="维护操作"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ClearCacheButton"
                                x:FieldModifier="public"
                                Content="清理缩略图缓存"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        <Button x:Name="ResetLibraryButton"
                                x:FieldModifier="public"
                                Content="清理缓存并重置库"
                                Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        <Button x:Name="ClearAllButton"
                                x:FieldModifier="public"
                                Content="清理全部应用数据"
                                Style="{StaticResource PrimaryToolbarButtonStyle}" />
                    </StackPanel>

                    <TextBlock Text="修改数据目录或便携模式后，建议重启应用以切换到新的数据库位置。受保护文件夹需要在“锁定管理”里输入密码后才会显示媒体。"
                               Foreground="{ThemeResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
