<Window
    x:Class="JvJvMediaManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:JvJvMediaManager"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="媒体管理器">

    <Grid x:Name="WindowRoot"
          Background="Transparent">
        <Rectangle Fill="{ThemeResource WindowBackdropBrush}"
                   IsHitTestVisible="False" />
        <Rectangle Fill="{ThemeResource HeroPanelBrush}"
                   IsHitTestVisible="False" />
        <Rectangle Fill="{ThemeResource WindowAmbientBrush}"
                   IsHitTestVisible="False" />
        <Rectangle Fill="{ThemeResource WindowSheenBrush}"
                   VerticalAlignment="Top"
                   Height="180"
                   IsHitTestVisible="False" />

        <Grid RowDefinitions="Auto,*">
            <Grid x:Name="AppTitleBar"
                  Height="44"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftInsetColumn" Width="0" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="RightInsetColumn" Width="0" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="1"
                      Margin="3,2,3,0"
                      Padding="0"
                      Background="{ThemeResource ShellTopBarBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="24"
                            Height="24"
                            Background="{ThemeResource AppIconBadgeBrush}"
                            CornerRadius="{ThemeResource RadiusSmall}"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8A5;"
                                  FontSize="13"
                                  Foreground="{ThemeResource MutedTextBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                    </Border>

                    <TextBlock x:Name="WindowTitleText"
                               Grid.Column="2"
                               Text="JvJv Media Manager"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />

                    <Button Grid.Column="4"
                            Click="TitleBarAddFilesButton_Click"
                            Style="{StaticResource TitleBarIconButtonStyle}"
                            ToolTipService.ToolTip="添加文件">
                        <FontIcon Glyph="&#xE8B9;" />
                    </Button>

                    <Button Grid.Column="6"
                            Click="TitleBarAddFolderButton_Click"
                            Style="{StaticResource TitleBarIconButtonStyle}"
                            ToolTipService.ToolTip="添加文件夹">
                        <FontIcon Glyph="&#xE8B7;" />
                    </Button>

                    <Button Grid.Column="8"
                            Click="TitleBarSettingsButton_Click"
                            Style="{StaticResource TitleBarIconButtonStyle}"
                            ToolTipService.ToolTip="设置">
                        <FontIcon Glyph="&#xE713;" />
                    </Button>
                </Grid>
            </Grid>

            <Frame x:Name="RootFrame"
                   Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
