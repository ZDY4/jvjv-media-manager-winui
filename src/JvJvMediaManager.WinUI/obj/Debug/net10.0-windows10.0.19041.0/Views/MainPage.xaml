<Page
    x:Class="JvJvMediaManager.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JvJvMediaManager.Models"
    xmlns:viewModels="using:JvJvMediaManager.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource SurfaceBrush}">

    <Page.Resources>
        <DataTemplate x:Key="ListItemTemplate"                                           >
            <Grid x:ConnectionId='12' Padding="8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="72" Height="48" Background="#2D2D2D" CornerRadius="6">
                    <Image x:ConnectionId='18'                             Stretch="UniformToFill" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock x:ConnectionId='13'                          Foreground="{ThemeResource TextBrush}" FontSize="14" TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock x:ConnectionId='15'                          Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                        <TextBlock x:ConnectionId='16'                                Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                        <TextBlock x:ConnectionId='17'                              Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                    </StackPanel>
                    <TextBlock x:ConnectionId='14'                          Foreground="#60CDFF" FontSize="11" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="GridItemTemplate"                                           >
            <Grid x:ConnectionId='6' Width="{Binding ElementName=GridView, Path=Tag}" Height="{Binding ElementName=GridView, Path=Tag}">
                <Border CornerRadius="8" Background="#2D2D2D">
                    <Image x:ConnectionId='10'                             Stretch="UniformToFill" />
                </Border>
                <Border Background="#99000000" VerticalAlignment="Bottom" CornerRadius="0,0,8,8" Padding="6">
                    <StackPanel Spacing="2">
                        <TextBlock x:ConnectionId='7'                          Foreground="{ThemeResource TextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:ConnectionId='8'                          Foreground="{ThemeResource MutedTextBrush}" FontSize="10" />
                        <TextBlock x:ConnectionId='9'                          Foreground="#60CDFF" FontSize="10" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PlaylistTemplate"                             >
            <Grid x:ConnectionId='3' Padding="8,6">
                <TextBlock x:ConnectionId='4'                      Foreground="{ThemeResource TextBrush}" TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" Background="{ThemeResource SurfaceAltBrush}" DefaultLabelPosition="Collapsed">
            <AppBarButton x:ConnectionId='65' Icon="Add" Label="添加文件"                        />
            <AppBarButton x:ConnectionId='66' Icon="Folder" Label="添加文件夹"                         />
            <AppBarButton x:ConnectionId='67' Icon="Sync" Label="刷新"                       />
            <AppBarSeparator />
            <AppBarButton x:ConnectionId='68' Icon="Tag" Label="编辑标签"                        />
            <AppBarButton x:ConnectionId='69' Icon="Library" Label="加入播放列表"                             />
            <AppBarButton x:ConnectionId='70' Label="锁定管理"                          />
            <AppBarSeparator />
            <AppBarButton x:ConnectionId='71' Icon="Setting" Label="设置"                        />
        </CommandBar>

        <SplitView Grid.Row="1" DisplayMode="Inline" IsPaneOpen="True" OpenPaneLength="420" Background="{ThemeResource SurfaceBrush}">
            <SplitView.Pane>
                <Grid x:ConnectionId='19' Background="{ThemeResource SurfaceAltBrush}" AllowDrop="True"                                                          >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Padding="12" Spacing="8">
                        <TextBox x:ConnectionId='32' x:Name="SearchBox"
                                 PlaceholderText="搜索文件名或输入 #标签"
                                                                    
                                                             />
                        <TextBlock Text="{Binding CurrentScopeTitle}" Foreground="{ThemeResource TextBrush}" FontSize="13" FontWeight="SemiBold" />
                        <ItemsControl x:ConnectionId='33' x:Name="SelectedTagsControl" Visibility="Collapsed">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate                      >
                                    <Button x:ConnectionId='35'                                
                                            Tag="{Binding}"
                                            Margin="0,0,6,6"
                                            Padding="8,3"
                                            Background="#1F005FB8"
                                            Foreground="#60CDFF"
                                            BorderThickness="0"
                                            CornerRadius="6"
                                            Content="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Padding="12,0,12,12" Spacing="6">
                        <ProgressBar x:ConnectionId='30' x:Name="ScanProgressBar"
                                     Minimum="0"
                                     Maximum="{Binding ScanProgressMaximum}"
                                     Value="{Binding ScanProgressValue}" />
                        <TextBlock x:ConnectionId='31' x:Name="ScanPathText"
                                   Text="{Binding ScanCurrentPath}"
                                   Foreground="{ThemeResource MutedTextBrush}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Foreground="{ThemeResource MutedTextBrush}" Text="{Binding StatusMessage}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Padding="12,0,12,12" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:ConnectionId='26' Content="全部媒体"                        />
                            <Button x:ConnectionId='27' Content="新建列表"                              />
                            <Button x:ConnectionId='28' Content="重命名"                              />
                            <Button x:ConnectionId='29' Content="删除"                              />
                        </StackPanel>
                        <ListView x:ConnectionId='25' x:Name="PlaylistListView"
                                  ItemsSource="{Binding Playlists}"
                                  ItemTemplate="{StaticResource PlaylistTemplate}"
                                  SelectionMode="Single"
                                  MaxHeight="164"
                                                                                      
                                  CanDragItems="True"
                                  CanReorderItems="True"
                                  AllowDrop="True"
                                                                                           />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Padding="12,0,12,12" Spacing="8">
                        <Button x:ConnectionId='22' Content="列表"                            />
                        <Button x:ConnectionId='23' Content="网格"                            />
                        <Button x:ConnectionId='24' Content="排序"                    />
                    </StackPanel>

                    <Grid Grid.Row="4">
                        <ListView x:ConnectionId='20' x:Name="ListView"
                                  ItemsSource="{Binding FilteredMediaItems}"
                                  ItemTemplate="{StaticResource ListItemTemplate}"
                                  IncrementalLoadingTrigger="Edge"
                                  IncrementalLoadingThreshold="2"
                                  DataFetchSize="1"
                                  SelectionMode="Extended"
                                  IsItemClickEnabled="True"
                                                             
                                                                                           
                                                                           
                                                                      />

                        <GridView x:ConnectionId='21' x:Name="GridView"
                                  Tag="140"
                                  Visibility="Collapsed"
                                  ItemsSource="{Binding FilteredMediaItems}"
                                  ItemTemplate="{StaticResource GridItemTemplate}"
                                  IncrementalLoadingTrigger="Edge"
                                  IncrementalLoadingThreshold="2"
                                  DataFetchSize="1"
                                  SelectionMode="Extended"
                                  IsItemClickEnabled="True"
                                                             
                                                                                           
                                                                           
                                                                     
                                                                                    >
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid ItemWidth="140" ItemHeight="140" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                        </GridView>
                    </Grid>
                </Grid>
            </SplitView.Pane>

            <SplitView.Content>
                <Grid x:ConnectionId='36' x:Name="PlayerRoot" Background="#202020"                                                                                                                           >
                    <Grid x:ConnectionId='37' x:Name="EmptyState" Visibility="Visible">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                            <TextBlock Text="选择一个媒体文件开始播放" Foreground="{ThemeResource TextBrush}" FontSize="18" />
                            <TextBlock Text="拖拽文件或文件夹到左侧即可导入" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                            <TextBlock Text="PageUp / PageDown 切换上一个/下一个" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>

                    <MediaPlayerElement x:ConnectionId='38' x:Name="VideoPlayer" AreTransportControlsEnabled="False" AutoPlay="True" Visibility="Collapsed" Stretch="Uniform" />
                    <ScrollViewer x:ConnectionId='39' x:Name="ImageScrollViewer"
                                  Visibility="Collapsed"
                                  ZoomMode="Enabled"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollMode="Enabled"
                                  MinZoomFactor="0.2"
                                  MaxZoomFactor="6"
                                                                                             >
                        <Image x:ConnectionId='64' x:Name="ImageViewer" Stretch="Uniform" />
                    </ScrollViewer>

                    <Grid x:ConnectionId='40' x:Name="PlayerOverlay" Background="Transparent">
                        <Grid x:ConnectionId='41' x:Name="ControlBar"
                              VerticalAlignment="Bottom"
                              Margin="16"
                              Padding="12"
                              Background="#99000000"
                              CornerRadius="10"
                                                                    >
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Slider x:ConnectionId='42' x:Name="ProgressSlider"
                                    Grid.Row="0"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="0"
                                    SmallChange="1"
                                    LargeChange="10"
                                                                              
                                                                                  
                                                                                     />

                            <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <AppBarButton x:ConnectionId='57' x:Name="PlayPauseButton" Grid.Column="0"                        >
                                    <AppBarButton.Icon>
                                        <SymbolIcon x:ConnectionId='63' x:Name="PlayPauseIcon" Symbol="Play" />
                                    </AppBarButton.Icon>
                                </AppBarButton>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock x:ConnectionId='61' x:Name="CurrentTimeText" Text="0:00" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                    <TextBlock Text="/" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                                    <TextBlock x:ConnectionId='62' x:Name="TotalTimeText" Text="0:00" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                                </StackPanel>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="音量" Foreground="{ThemeResource MutedTextBrush}" FontSize="12" />
                                    <Slider x:ConnectionId='60' x:Name="VolumeSlider" Width="110" Minimum="0" Maximum="1" Value="0.8"                                          />
                                </StackPanel>

                                <Button x:ConnectionId='58' x:Name="PlaybackModeButton" Grid.Column="4" Content="列表循环"                            />
                                <Button x:ConnectionId='59' x:Name="FullScreenButton" Grid.Column="5" Content="全屏"                          />
                            </Grid>

                            <Border x:ConnectionId='43' x:Name="ClipBar"
                                    Grid.Row="2"
                                    Margin="0,10,0,0"
                                    Padding="10,8"
                                    Background="#55000000"
                                    CornerRadius="8"
                                    Visibility="Collapsed">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:ConnectionId='52' x:Name="SetClipStartButton" Content="标记入点 (I)"                            />
                                        <Button x:ConnectionId='53' x:Name="SetClipEndButton" Content="标记出点 (O)"                          />
                                        <Button x:ConnectionId='54' x:Name="ClipPlanButton" Content="片段方案..."                        />
                                        <Button x:ConnectionId='55' x:Name="ClearClipButton" Content="重置区间"                         />
                                        <Button x:ConnectionId='56' x:Name="ExportClipButton" Content="导出剪辑 (E)"                          />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <TextBlock x:ConnectionId='49' x:Name="ClipStartText" Text="入点：0:00" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                        <TextBlock x:ConnectionId='50' x:Name="ClipEndText" Text="出点：0:00" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                        <TextBlock x:ConnectionId='51' x:Name="ClipDurationText" Text="时长：0:00" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <TextBlock x:ConnectionId='46' x:Name="ClipModeText" Text="模式：保留片段" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                        <TextBlock x:ConnectionId='47' x:Name="ClipSegmentCountText" Text="片段：1" Foreground="{ThemeResource TextBrush}" FontSize="12" />
                                        <TextBlock x:ConnectionId='48' x:Name="ClipOutputText" Text="输出：原目录" Foreground="{ThemeResource TextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <ProgressBar x:ConnectionId='44' x:Name="ClipExportProgressBar"
                                                     Width="180"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="0"
                                                     Visibility="Collapsed" />
                                        <TextBlock x:ConnectionId='45' x:Name="ClipStatusText"
                                                   Foreground="{ThemeResource MutedTextBrush}"
                                                   FontSize="12"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Page>

